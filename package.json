{
  "name": "vtk-website",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "verify": "npm run verify:lockfile && npm run verify:types && npm run lint && npm run test --workspace=@vtk/web",
    "verify:types": "npm exec --workspace=@vtk/web -- next typegen && tsc --noEmit -p apps/web/tsconfig.json",
    "verify:lockfile": "node scripts/check-lockfile-platforms.mjs",
    "dev": "npm run dev --workspace=@vtk/web",
    "build": "npm run build --workspace=@vtk/db && npm run build --workspace=@vtk/web",
    "start": "npm run start --workspace=@vtk/web",
    "lint": "npm run lint --workspace=@vtk/web",
    "db:generate": "npm run generate --workspace=@vtk/db",
    "db:push": "npm run push --workspace=@vtk/db",
    "db:migrate": "npm run migrate --workspace=@vtk/db",
    "db:seed": "npm run seed --workspace=@vtk/db"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0"
  },
  "dependencies": {
    "date-fns": "^4.4.0"
  }
}
