# Copy to .env (at repo root) and fill in.

# Postgres
DATABASE_URL="postgresql://vtk:vtk@localhost:5432/vtk?schema=public"
POSTGRES_USER="vtk"
POSTGRES_PASSWORD="vtk"
POSTGRES_DB="vtk"

# Session cookie that is shared across subdomains. Use ".vtk.be" in production.
SESSION_COOKIE_DOMAIN=""

# Base URL of the main web app. Used by submodules to verify sessions remotely.
VTK_MAIN_URL="http://localhost:3000"

# MinIO / S3 object storage
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="vtk"
S3_REGION="us-east-1"
S3_PUBLIC_URL="http://localhost:9000/vtk"

# Optional: create a first superadmin on `npm run db:seed`.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Immich gallery shown on the public Media page. The API key stays server-side.
# Use http://host.docker.internal:2283/api when the web app runs in Docker on macOS.
GALLERY_IMMICH_API_URL="http://localhost:2283/api"
GALLERY_IMMICH_API_KEY=""
GALLERY_PUBLIC_PROXY_URL="http://localhost:3001"
GALLERY_ALBUM_MARKER="[gallery]"
GALLERY_CACHE_TTL_SECONDS="60"
GALLERY_DATABASE_HOST=""
GALLERY_DATABASE_PORT="5432"
GALLERY_DATABASE_NAME=""
GALLERY_DATABASE_USER=""
GALLERY_DATABASE_PASSWORD=""
GALLERY_FACE_SEARCH_ENABLED="true"
GALLERY_FACE_SEARCH_MAX_UPLOAD_BYTES="8388608"
GALLERY_FACE_SEARCH_TIMEOUT_SECONDS="240"
GALLERY_FACE_SEARCH_POLL_INTERVAL_MS="2500"
GALLERY_FACE_SEARCH_MAX_JOBS="50"
GALLERY_FACE_SEARCH_MIN_FACE_AREA_RATIO="0.008"
GALLERY_FACE_SEARCH_DOMINANT_FACE_AREA_RATIO="2.2"
GALLERY_FACE_MATCH_MAX_DISTANCE="0.42"
GALLERY_FACE_MATCH_MAX_RESULTS="80"

# Better auth variables
# openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-me-with-a-secret"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"
BETTER_AUTH_COOKIE_DOMAIN=".vtk.be"

# KU Leuven SSO (OpenID Connect). Leave blank to disable the "Sign in with
# KU Leuven" button and run with email/password only. KU Leuven uses the
# Shibboleth OIDC OP of the Associatie KU Leuven, so the discovery URL is the
# Shibboleth issuer (ICTS gives you the exact value), e.g.
#   https://idp.kuleuven.be/.well-known/openid-configuration
KUL_OIDC_DISCOVERY_URL=""
# KUL_OIDC_CLIENT_ID is also the "Entity ID" you enter in the Shibboleth tool.
# It is a stable identifier and should stay the same across deployments.
KUL_OIDC_CLIENT_ID=""
KUL_OIDC_CLIENT_SECRET=""
# The redirect/callback URI is derived automatically from BETTER_AUTH_URL as
#   <BETTER_AUTH_URL>/api/auth/better/oauth2/callback/kuleuven
# Only set this to override it. Visit /sso-metadata (as superadmin) to see the
# exact values to register for the current deployment.
KUL_OIDC_REDIRECT_URI=""
