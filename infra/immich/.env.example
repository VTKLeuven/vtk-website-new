# Copy this file to infra/immich/.env on each deployed host and replace every
# example password. Compose loads this file only into Immich and the web
# container; it is not exposed to the browser.
TZ=Europe/Brussels

# Immich API database settings.
DB_PASSWORD=replace-with-a-strong-immich-database-password
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# The Immich PostgreSQL image reads POSTGRES_*, while Immich reads DB_* above.
# Keep these three values identical to their DB_* counterparts.
POSTGRES_PASSWORD=replace-with-a-strong-immich-database-password
POSTGRES_USER=immich
POSTGRES_DB=immich

# The website reads the same database directly for face search.
GALLERY_DATABASE_PORT=5432
GALLERY_DATABASE_NAME=immich
GALLERY_DATABASE_USER=immich
GALLERY_DATABASE_PASSWORD=replace-with-a-strong-immich-database-password

# Must match the public Caddy hostname that proxies to 127.0.0.1:3001.
PUBLIC_BASE_URL=http://localhost:3001

# Local URLs and first-run credentials used only by the optional seed script.
IMMICH_URL=http://localhost:2283
PUBLIC_PROXY_URL=http://localhost:3001
IMMICH_ADMIN_EMAIL=portfolio@example.test
IMMICH_ADMIN_PASSWORD=replace-with-a-strong-immich-admin-password
IMMICH_ADMIN_NAME="Immich Admin"
GALLERY_ALBUM_MARKER=[gallery]
