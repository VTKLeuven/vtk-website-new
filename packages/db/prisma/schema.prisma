// VTK website Prisma schema.
// Generated client lands in @vtk/db/node_modules/.prisma/client for each package.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum Locale {
  NL
  EN
}

enum MembershipRole {
  MEMBER
  LEAD
}

// Soort Group. PRAESIDIUM = een praesidiumpost (op /praesidium). WERKGROEP = een
// werkgroep (BEST, Revue, ...): dezelfde leden/rollen-machinerie, maar niet op
// /praesidium; ze verschijnen op /werkgroepen met een eigen infotekst + website.
enum GroupType {
  PRAESIDIUM
  WERKGROEP
}

// Hoe een post (Group) een rol toekent aan haar leden.
// DEFAULT: elk lid van de post krijgt de rol. LEADER: enkel de
// verantwoordelijke (membership.role == LEAD) krijgt de rol, bovenop de
// DEFAULT-rollen van de post.
enum RoleGrantKind {
  DEFAULT
  LEADER
}

// Wie mag inloggen bij een OAuth-client.
// OPEN: elk actief lid; permissies bepalen enkel wat je er méér mag (de
// cudi-tool). RESTRICTED: enkel wie de `<namespace>.access`-permissie van die
// client houdt, geraakt er binnen (de interne wiki). De blokkade zit in de
// autorisatieflow zelf, niet in de applicatie.
enum SsoAccessMode {
  OPEN
  RESTRICTED
}

enum PageAssetKind {
  EMBEDDED_PDF
  DOWNLOAD
}

enum EventVisibility {
  PUBLIC
  MEMBERS
}

enum DashboardTileScope {
  GLOBAL
  GROUP
  USER
}

enum TicketEventStatus {
  DRAFT
  PUBLISHED
  SALES_PAUSED
  SALES_CLOSED
  CANCELLED
  ARCHIVED
}

enum TicketAudience {
  PUBLIC
  MEMBERS
}

enum TicketQuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  BOOLEAN
}

enum TicketGrantRole {
  OWNER
  MANAGER
  FINANCE
  SCANNER
  REPORTER
}

enum TicketGroupGrantScope {
  ALL_MEMBERS
  LEADS_ONLY
}

enum TicketOrderStatus {
  PENDING_PAYMENT
  PAID
  PAYMENT_FAILED
  EXPIRED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum TicketPaymentStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum TicketRefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum TicketStatus {
  VALID
  VOID
  REFUNDED
}

enum TicketScanResult {
  ACCEPTED
  ALREADY_USED
  WRONG_EVENT
  INVALID
  VOID
  REFUNDED
  EXPIRED
  REVERSED
}

enum TicketOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DEAD
}

enum TheokotOrderStatus {
  RESERVED // gereserveerd, nog niet opgehaald
  PICKED_UP // afgehaald aan de balie
  NO_SHOW // niet opgehaald na sluitingstijd + grace
  CANCELLED // door de student geannuleerd voor de deadline
}

enum UitleenReservationStatus {
  REQUESTED // aangevraagd, wacht op beslissing van Logistiek
  APPROVED // goedgekeurd; telt mee voor de voorraad
  REJECTED // afgewezen door Logistiek
  CANCELLED // door het lid geannuleerd
  PICKED_UP // materiaal afgehaald
  RETURNED // materiaal teruggebracht; reservatie afgerond
}

enum UitleenTransportBookingStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED // rit uitgevoerd
}

// Namens wie een aanvraag gebeurt. De drie kanalen uit de Logi-werking met elk
// een eigen behandelaar: interne posten, werkgroepen/jaarwerkingen, externen.
enum UitleenRequesterType {
  INTERN // eigen post (praesidium)
  WERKGROEP // werkgroep of jaarwerking
  EXTERN // extern of individueel
}

// Hoe de prijs van een voertuig berekend wordt. Team-configureerbaar per
// voertuig, want de kring bevestigt de tarieven nog.
enum UitleenPricingMode {
  FREE // gratis
  PER_HOUR // rateCents per begonnen uur
  PER_KM // rateCents per kilometer (km ingevuld bij afronden)
  FLAT // vast bedrag = rateCents
}

// Staat van een materiaalstuk. Puur informatief (badge in het beheer); muteert
// nooit automatisch de beschikbaarheid.
enum UitleenItemCondition {
  WERKT
  KAPOT
  TESTEN
  ONVOLLEDIG
}

// Hoe een goedgekeurde reservatie betaald wordt: online via de payment
// provider, of offline (cash/Payconiq) bij afhaling. Keuze van het team
// bij goedkeuring.
enum UitleenPaymentMode {
  ONLINE
  OFFLINE
}

enum UitleenPaymentStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

// Hoe een deurgebeurtenis tot stand kwam: een fysieke kaartscan aan de deur, of
// een remote-open vanaf het dashboard.
enum DoorMethod {
  CARD
  REMOTE
}

// De uitkomst van een deurgebeurtenis.
enum DoorLogResult {
  ALLOWED // deur ging open
  DENIED // gekende gebruiker zonder toegang
  UNKNOWN_CARD // kaart geverifieerd maar niet aan een gebruiker gekoppeld
  ERROR // verificatie/lookup mislukt
}

// Welk e-mailadres de kring gebruikt om een lid te contacteren.
enum EmailPreference {
  UNIVERSITY // universiteitsmail (= login-mail via KUL SSO)
  PERSONAL // persoonlijke mail
}

// Mailinglijst-categorieën waarvoor een lid zich (opt-in) kan inschrijven.
enum MailCategory {
  FEEST
  CAREER
  SPORT
  EVENEMENTEN
  ONDERWIJS
  INTERNATIONAAL
  EERSTEJAARS
  BAKSKE
}

// In welk studiejaar een lid zit.
enum StudyYear {
  BACHELOR_1
  BACHELOR_2
  BACHELOR_3
  MASTER_1
  MASTER_2
}

// Studierichtingen (een lid kan er meerdere aanduiden). Labels (NL/EN) leven in
// de i18n-dictionaries, niet in de enum.
enum StudyProgramme {
  ARCHITECTURE
  BIOMEDICAL
  COMMON_BACHELOR
  CIVIL
  CHEMICAL
  COMPUTER_SCIENCE
  CYBERSECURITY
  DIGITAL_HUMANITIES
  ELECTRICAL
  ENERGY
  ARTIFICIAL_INTELLIGENCE
  MATERIALS
  NANO
  URBANISM
  MATHEMATICAL
  MECHANICAL
}

// -----------------------------------------------------------------------------
// Users, groups, permissions
// -----------------------------------------------------------------------------

model User {
  id             String  @id @default(cuid())
  // `name` blijft de weergavenaam (en het veld dat better-auth zelf zet bij een
  // SSO-login). `firstName`/`lastName` zijn de gestructureerde variant die de
  // mailinglijst-exports nodig hebben; ze worden ingevuld tijdens de onboarding
  // en in het gebruikersbeheer, en `name` wordt daaruit samengesteld.
  name           String
  firstName      String?
  lastName       String?
  email          String  @unique
  rNumber        String? @unique // KU Leuven studentennummer (bvb r0123456), voor zoeken
  // `true` als het r-nummer van de KU Leuven-authenticator komt (bij SSO gezet,
  // zie packages/auth/src/logins/kul.ts). Dan staat het veld read-only in het
  // profielformulier, net als de e-mail; een zelf ingevuld r-nummer (flag false)
  // blijft aanpasbaar.
  rNumberFromKul Boolean @default(false)
  emailVerified  Boolean @default(false)
  avatarKey      String?
  image          String?

  locale       Locale  @default(NL)
  active       Boolean @default(true)
  isSuperAdmin Boolean @default(false)

  // Gezet door `eraseUserData` (lib/privacy/account.ts). De User-rij zelf kan niet
  // weg: te veel tabellen (theokot, uitleen, shifts) hangen er met een FK aan, dus
  // wordt ze geanonimiseerd tot een tombstone. Dat is bewust iets anders dan
  // `active: false`, wat een gewoon gedeactiveerd lid is dat je in het beheer nog
  // wil zien. Filter `deletedAt: null` in elke lijst die gebruikers toont.
  deletedAt    DateTime?

  // Onboarding-profiel (ingevuld bij de eerste KUL SSO-login). Zolang
  // onboardedAt null is, wordt het lid naar de onboarding-flow gestuurd.
  onboardedAt        DateTime?
  // Kotadres
  street             String?
  houseNumber        String?
  bus                String? // busnummer, optioneel
  postalCode         String?
  city               String?
  birthDate          DateTime?
  // Contact: `email` is de login-/universiteitsmail (via SSO). Persoonlijke
  // mail en de voorkeur voor communicatie komen erbij.
  personalEmail      String?
  emailPreference    EmailPreference  @default(UNIVERSITY)
  // Opt-in mailinglijsten: enkel de aangeduide categorieën zitten in de array.
  mailCategories     MailCategory[]   @default([])
  // Studie: meerdere studiejaren en richtingen mogelijk (iemand kan bv. deels in
  // 2de en deels in 3de bachelor zitten).
  studyYears         StudyYear[]      @default([])
  studyProgrammes    StudyProgramme[] @default([])
  // Lid dat niet aan de faculteit Ingenieurswetenschappen studeert. Bewust geen
  // `StudyProgramme`-waarde: het is geen richting, en als enum-waarde zou het
  // overal opduiken waar richtingen opgelijst worden (o.a. de career-export).
  notAtFaculty       Boolean          @default(false)
  // Lid dat niet (meer) studeert: afgestudeerd of gestopt. Bewust los van
  // `notAtFaculty` (dat is "studeert wél, maar elders"): wie dit aanduidt valt
  // uit élke studiegerichte mailinglijst (zie lib/mailinglists.ts). Blijft een
  // aparte boolean om dezelfde reden als notAtFaculty.
  notStudying        Boolean          @default(false)
  // Werkingsjaar waarin het lid zijn studieprofiel laatst bevestigde (2026 =
  // "26-27"). Loopt dat achter op het huidige werkingsjaar, dan is het profiel
  // verlopen: de bevestigingsgate vraagt het opnieuw en het lid valt zolang uit
  // de mailinglijsten. Zo blijft "actief student" een jaarlijks vers signaal
  // zonder koppeling met de cursusdienst.
  studyConfirmedYear Int?

  sessions  Session[]
  accounts  Account[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  memberships         GroupMembership[]
  roles               UserRole[]
  pocRepresentative   PocRepresentative[]
  createdPages        Page[]                  @relation("PageCreatedBy")
  createdEvents       CalendarEvent[]         @relation("EventCreatedBy")
  dashboardTiles      DashboardTile[]
  dashboardTilePrefs  UserDashboardTilePref[]
  participatingShifts ShiftParticipant[]
  createdShortLinks   ShortLink[]             @relation("ShortLinkCreatedBy")

  theokotOrders             TheokotOrder[]             @relation("TheokotOrderUser")
  theokotPickedUp           TheokotOrder[]             @relation("TheokotPickedUpBy")
  theokotVoucherRedemptions TheokotVoucherRedemption[] @relation("TheokotVoucherUser")
  theokotVouchersProcessed  TheokotVoucherRedemption[] @relation("TheokotVoucherProcessedBy")
  theokotBans               TheokotBan[]

  uitleenReservations     UitleenReservation[]      @relation("UitleenReservationUser")
  uitleenDecided          UitleenReservation[]      @relation("UitleenDecidedBy")
  uitleenPickedUp         UitleenReservation[]      @relation("UitleenPickedUpBy")
  uitleenReturned         UitleenReservation[]      @relation("UitleenReturnedBy")
  uitleenTransport        UitleenTransportBooking[] @relation("UitleenTransportUser")
  uitleenTransportDriven  UitleenTransportBooking[] @relation("UitleenTransportDriver")
  uitleenTransportDecided UitleenTransportBooking[] @relation("UitleenTransportDecidedBy")
  uitleenTransportDone    UitleenTransportBooking[] @relation("UitleenTransportCompletedBy")

  doorGrants         DoorAccessGrant[]
  doorLogs           DoorAccessLog[]
  doorShortcutTokens DoorShortcutToken[]

  createdTicketEvents      TicketEvent[]           @relation("TicketEventCreatedBy")
  ticketEventGrants        TicketEventUserGrant[]  @relation("TicketEventGrantUser")
  ticketEventGrantsGiven   TicketEventUserGrant[]  @relation("TicketEventGrantGrantedBy")
  ticketGroupGrantsGiven   TicketEventGroupGrant[] @relation("TicketEventGroupGrantGrantedBy")
  ticketOrders             TicketOrder[]           @relation("TicketOrderBuyer")
  requestedTicketRefunds   TicketRefund[]          @relation("TicketRefundRequestedBy")
  createdTicketScanDevices TicketScanDevice[]      @relation("TicketScanDeviceCreatedBy")
  ticketScans              TicketScanLog[]         @relation("TicketScanActor")
  ticketAuditLogs          TicketAuditLog[]        @relation("TicketAuditActor")
  checkedInTickets         Ticket[]                @relation("TicketCheckedInBy")

  //Oauth / SSO fields
  oauthClients             OauthClient[]
  oauthRefreshTokens       OauthRefreshToken[]
  oauthAccessTokens        OauthAccessToken[]
  oauthConsents            OauthConsent[]
  ssoAuditLogs             SsoAuditLog[]
  ssoClientPermissions     SsoUserClientPermission[]

  @@index([deletedAt])
}

model Group {
  id                String    @id @default(cuid())
  // Vrije, GUI-beheerde code (was een `GroupCode`-enum). Uniek, en de waarde die
  // shiften opslaan in `Shift.post` en de sessie meegeeft als `groups[].code`.
  code              String    @unique
  slug              String    @unique
  nameNl            String
  nameEn            String
  descriptionNl     String?
  descriptionEn     String?
  orderInPraesidium Int       @default(0)
  photoKey          String?
  // Praesidiumpost of werkgroep. Een werkgroep gebruikt dezelfde leden/rollen
  // maar staat niet op /praesidium; ze krijgt /werkgroepen met haar eigen
  // infotekst (description*, door de leden zelf bewerkbaar) en optionele website.
  type              GroupType @default(PRAESIDIUM)
  website           String?
  // Een gedeactiveerde post verdwijnt uit de nieuwe-shift-keuzes en het
  // postenbeheer voor nieuwe jaren, maar de historiek (memberships per jaar)
  // blijft bewaard i.p.v. de post te verwijderen.
  active            Boolean   @default(true)

  memberships       GroupMembership[]
  // Rollen die deze post toekent aan haar leden (DEFAULT) en verantwoordelijke (LEADER).
  roleGrants        GroupRole[]
  events            CalendarEvent[]
  dashboardTiles    DashboardTile[]
  ownedTicketEvents TicketEvent[]           @relation("TicketEventOwnerGroup")
  ticketEventGrants TicketEventGroupGrant[]
  ssoGrants         SsoGroupClientPermission[]

  uitleenReservations UitleenReservation[]
  uitleenTransport    UitleenTransportBooking[]
}

model GroupMembership {
  id           String         @id @default(cuid())
  userId       String
  groupId      String
  role         MembershipRole @default(MEMBER)
  // Werkingsjaar (startjaar van het academiejaar): 2026 = "26-27". Elk jaar is
  // een aparte rij, zodat de historiek per post per jaar bewaard blijft en een
  // nieuw werkingsjaar automatisch met een lege post begint.
  year         Int
  titleNl      String?
  titleEn      String?
  displayOrder Int            @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, year])
  @@index([groupId])
  @@index([year])
}

model Permission {
  id       String @id @default(cuid())
  code     String @unique
  labelNl  String
  labelEn  String
  category String @default("general")

  roles RolePermission[]
}

// Een rol bundelt rechten. Leden krijgen rollen direct (UserRole) of via een
// post (GroupRole). Roldefinities blijven over de jaren heen bestaan; enkel de
// toewijzingen zijn werkingsjaar-gebonden (zie UserRole) en resetten op 15 juli.
// `system` markeert rollen die de GUI niet mag verwijderen (bv. admin).
model Role {
  id            String   @id @default(cuid())
  code          String   @unique
  nameNl        String
  nameEn        String
  descriptionNl String?
  descriptionEn String?
  // Optionele accentkleur voor de rol-pill in de UI (key in het paletsysteem).
  color         String?
  order         Int      @default(0)
  system        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]
  groupGrants GroupRole[]
  pageGrants  PageEditorRole[]
  ssoGrants   SsoRoleClientPermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// Directe roltoewijzing aan een gebruiker, per werkingsjaar (2026 = "26-27").
// Net als GroupMembership per jaar: een nieuw werkingsjaar begint met een lege
// toewijzing (de 15-juli-reset) en de historiek blijft bewaard. De uitzondering
// die niet reset is `User.isSuperAdmin` (een boolean, geen toewijzing).
model UserRole {
  userId String
  roleId String
  year   Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId, year])
  @@index([userId])
  @@index([roleId])
  @@index([year])
}

// Rollen die een post automatisch toekent. DEFAULT geldt voor elk lid, LEADER
// enkel voor de verantwoordelijke (bovenop DEFAULT). Deze grants worden niet per
// persoon opgeslagen: de sessie-resolver leidt ze af uit de lidmaatschappen.
model GroupRole {
  groupId String
  roleId  String
  kind    RoleGrantKind @default(DEFAULT)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([groupId, roleId, kind])
  @@index([groupId])
  @@index([roleId])
}

// -----------------------------------------------------------------------------
// Header tabs & pages CMS
// -----------------------------------------------------------------------------

model HeaderTab {
  id      String  @id @default(cuid())
  code    String  @unique
  slug    String  @unique
  labelNl String
  labelEn String
  order   Int     @default(0)
  visible Boolean @default(true)

  // Foto op de aanbod-kaart van deze werking op de homepage (storage-key,
  // uploadbaar via /admin/home). Zonder foto valt de kaart terug op het
  // gestreepte placeholder-patroon of de statische default in HomeEditorial.
  imageKey String?

  // Inhoud van de categoriepagina zelf, bewerkbaar via /admin/inhoud.
  introNl    String?
  introEn    String?
  // Optionele knop naast de titel (bv. cudi.vtk.be bij Cursusdienst).
  ctaLabelNl String?
  ctaLabelEn String?
  ctaUrl     String?

  pages Page[]
}

model Page {
  id              String    @id @default(cuid())
  slug            String    @unique
  headerTabId     String?
  visibleInHeader Boolean   @default(true)
  titleNl         String
  titleEn         String?
  // Legacy tiptap-documenten. Markdown (contentMdNl/En) is de bron van waarheid;
  // deze JSON wordt enkel nog gerenderd zolang de pagina niet één keer in de
  // markdown-editor opgeslagen is.
  contentJsonNl   Json
  contentJsonEn   Json?
  contentMdNl     String?
  contentMdEn     String?
  excerptNl       String?
  excerptEn       String?
  // Jaarlijks na te kijken pagina (namen, telefoonnummers, ...): komt bovenaan
  // het paginabeheer te staan zolang ze dit werkingsjaar niet bewerkt is.
  needsYearlyEdit Boolean   @default(false)
  // Laatste keer dat de INHOUD via de editor opgeslagen is. updatedAt telt niet:
  // die verschuift ook bij structuurwijzigingen (verslepen, hernoemen, ...).
  contentEditedAt DateTime?
  publishedAt     DateTime?
  order           Int       @default(0)
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  headerTab   HeaderTab?       @relation(fields: [headerTabId], references: [id], onDelete: SetNull)
  createdBy   User?            @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assets      PageAsset[]
  editorRoles PageEditorRole[]

  @@index([headerTabId])
}

// Rollen die de inhoud van een pagina mogen bewerken (naast superadmin en
// pages.editAll). Een pagina zonder rijen hier is vergrendeld voor gewone
// pages.edit-houders.
model PageEditorRole {
  pageId String
  roleId String

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([pageId, roleId])
  @@index([roleId])
}

model PageAsset {
  id         String        @id @default(cuid())
  pageId     String
  storageKey String
  kind       PageAssetKind
  labelNl    String
  labelEn    String?
  sizeBytes  Int?
  mimeType   String?
  order      Int           @default(0)
  createdAt  DateTime      @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

// -----------------------------------------------------------------------------
// Calendar
// -----------------------------------------------------------------------------

model CalendarEvent {
  id            String          @id @default(cuid())
  titleNl       String
  titleEn       String?
  descriptionNl String?
  descriptionEn String?
  location      String?
  start         DateTime
  end           DateTime
  allDay        Boolean         @default(false)
  visibility    EventVisibility @default(PUBLIC)
  url           String?
  imageKey      String?
  groupId       String
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  ticketEvent TicketEvent?

  @@index([start])
  @@index([groupId])
}

// -----------------------------------------------------------------------------
// Integrated ticketing
// -----------------------------------------------------------------------------

model TicketEvent {
  id                    String            @id @default(cuid())
  calendarEventId       String?           @unique
  ownerGroupId          String
  slug                  String            @unique
  titleNl               String
  titleEn               String?
  descriptionNl         String?
  descriptionEn         String?
  location              String?
  startsAt              DateTime          @db.Timestamptz(3)
  endsAt                DateTime          @db.Timestamptz(3)
  timeZone              String            @default("Europe/Brussels")
  salesStartAt          DateTime?         @db.Timestamptz(3)
  salesEndAt            DateTime?         @db.Timestamptz(3)
  status                TicketEventStatus @default(DRAFT)
  currency              String            @default("EUR")
  maxTicketsPerOrder    Int               @default(8)
  contactEmail          String?
  termsUrl              String?
  termsVersion          String?
  confirmationMessageNl String?
  confirmationMessageEn String?
  settings              Json              @default("{}")
  createdById           String?
  publishedAt           DateTime?         @db.Timestamptz(3)
  archivedAt            DateTime?         @db.Timestamptz(3)
  createdAt             DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime          @updatedAt @db.Timestamptz(3)

  calendarEvent CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  ownerGroup    Group          @relation("TicketEventOwnerGroup", fields: [ownerGroupId], references: [id], onDelete: Restrict)
  createdBy     User?          @relation("TicketEventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  inventoryPools TicketInventoryPool[]
  ticketTypes    TicketType[]
  questions      TicketQuestion[]
  userGrants     TicketEventUserGrant[]
  groupGrants    TicketEventGroupGrant[]
  orders         TicketOrder[]
  orderItems     TicketOrderItem[]
  tickets        Ticket[]
  gates          TicketGate[]
  scanDevices    TicketScanDevice[]
  scanLogs       TicketScanLog[]
  auditLogs      TicketAuditLog[]
  outboxMessages TicketOutboxMessage[]

  @@index([ownerGroupId])
  @@index([status, salesStartAt, salesEndAt])
  @@index([startsAt])
}

model TicketInventoryPool {
  id            String   @id @default(cuid())
  eventId       String
  code          String
  nameNl        String
  nameEn        String?
  capacity      Int
  reservedCount Int      @default(0)
  soldCount     Int      @default(0)
  version       Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  event       TicketEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypes TicketType[]
  orderItems  TicketOrderItem[]

  @@unique([eventId, code])
  @@unique([id, eventId])
  @@index([eventId, active])
}

model TicketType {
  id              String         @id @default(cuid())
  eventId         String
  inventoryPoolId String
  code            String
  nameNl          String
  nameEn          String?
  descriptionNl   String?
  descriptionEn   String?
  unitPriceCents  Int
  currency        String         @default("EUR")
  audience        TicketAudience @default(PUBLIC)
  salesStartAt    DateTime?      @db.Timestamptz(3)
  salesEndAt      DateTime?      @db.Timestamptz(3)
  minPerOrder     Int            @default(1)
  maxPerOrder     Int            @default(8)
  active          Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(3)

  event         TicketEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  inventoryPool TicketInventoryPool @relation(fields: [inventoryPoolId, eventId], references: [id, eventId], onDelete: Restrict)
  questions     TicketQuestion[]
  orderItems    TicketOrderItem[]

  @@unique([eventId, code])
  @@unique([id, eventId])
  @@index([eventId, active, sortOrder])
  @@index([inventoryPoolId])
}

model TicketQuestion {
  id            String             @id @default(cuid())
  eventId       String
  ticketTypeId  String?
  code          String
  labelNl       String
  labelEn       String?
  descriptionNl String?
  descriptionEn String?
  type          TicketQuestionType
  required      Boolean            @default(false)
  options       Json?
  active        Boolean            @default(true)
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(3)

  event      TicketEvent             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType TicketType?             @relation(fields: [ticketTypeId, eventId], references: [id, eventId], onDelete: Restrict)
  answers    TicketOrderItemAnswer[]

  @@unique([eventId, code])
  @@unique([id, eventId])
  @@index([eventId, active, sortOrder])
  @@index([ticketTypeId])
}

model TicketEventUserGrant {
  id          String          @id @default(cuid())
  eventId     String
  userId      String
  role        TicketGrantRole
  grantedById String?
  createdAt   DateTime        @default(now()) @db.Timestamptz(3)

  event     TicketEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User        @relation("TicketEventGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User?       @relation("TicketEventGrantGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([userId])
}

model TicketEventGroupGrant {
  id          String                @id @default(cuid())
  eventId     String
  groupId     String
  role        TicketGrantRole
  scope       TicketGroupGrantScope @default(ALL_MEMBERS)
  grantedById String?
  createdAt   DateTime              @default(now()) @db.Timestamptz(3)

  event     TicketEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  grantedBy User?       @relation("TicketEventGroupGrantGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([eventId, groupId])
  @@index([groupId])
}

model TicketOrder {
  id                   String            @id @default(cuid())
  eventId              String
  reference            String            @unique
  accessTokenHash      String            @unique
  accessExpiresAt      DateTime          @db.Timestamptz(3)
  requestFingerprint   String?
  buyerUserId          String?
  buyerName            String
  buyerEmail           String
  locale               Locale            @default(NL)
  status               TicketOrderStatus @default(PENDING_PAYMENT)
  currency             String            @default("EUR")
  subtotalCents        Int
  discountCents        Int               @default(0)
  totalCents           Int
  refundedCents        Int               @default(0)
  reservationExpiresAt DateTime?         @db.Timestamptz(3)
  termsAcceptedAt      DateTime?         @db.Timestamptz(3)
  termsVersion         String?
  paidAt               DateTime?         @db.Timestamptz(3)
  failedAt             DateTime?         @db.Timestamptz(3)
  expiredAt            DateTime?         @db.Timestamptz(3)
  cancelledAt          DateTime?         @db.Timestamptz(3)
  createdAt            DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime          @updatedAt @db.Timestamptz(3)

  event          TicketEvent           @relation(fields: [eventId], references: [id], onDelete: Restrict)
  buyer          User?                 @relation("TicketOrderBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  items          TicketOrderItem[]
  payments       TicketPayment[]
  refunds        TicketRefund[]
  outboxMessages TicketOutboxMessage[]

  @@unique([id, eventId])
  @@index([eventId, status, createdAt])
  @@index([eventId, requestFingerprint, createdAt])
  @@index([buyerUserId])
  @@index([buyerEmail])
  @@index([status, reservationExpiresAt])
}

// Each order item represents exactly one attendee and can issue at most one ticket.
model TicketOrderItem {
  id              String   @id @default(cuid())
  eventId         String
  orderId         String
  ticketTypeId    String
  inventoryPoolId String
  ticketTypeCode  String
  ticketTypeName  String
  unitPriceCents  Int
  discountCents   Int      @default(0)
  totalCents      Int
  attendeeName    String
  attendeeEmail   String?
  createdAt       DateTime @default(now()) @db.Timestamptz(3)

  event         TicketEvent             @relation(fields: [eventId], references: [id], onDelete: Restrict)
  order         TicketOrder             @relation(fields: [orderId, eventId], references: [id, eventId], onDelete: Restrict)
  ticketType    TicketType              @relation(fields: [ticketTypeId, eventId], references: [id, eventId], onDelete: Restrict)
  inventoryPool TicketInventoryPool     @relation(fields: [inventoryPoolId, eventId], references: [id, eventId], onDelete: Restrict)
  answers       TicketOrderItemAnswer[]
  ticket        Ticket?
  refundItems   TicketRefundItem[]

  @@unique([id, eventId])
  @@unique([id, orderId])
  @@index([orderId])
  @@index([eventId, ticketTypeId])
  @@index([inventoryPoolId])
}

model TicketOrderItemAnswer {
  id            String   @id @default(cuid())
  eventId       String
  orderItemId   String
  questionId    String
  questionCode  String
  questionLabel String
  value         Json
  createdAt     DateTime @default(now()) @db.Timestamptz(3)

  orderItem TicketOrderItem @relation(fields: [orderItemId, eventId], references: [id, eventId], onDelete: Restrict)
  question  TicketQuestion  @relation(fields: [questionId, eventId], references: [id, eventId], onDelete: Restrict)

  @@unique([orderItemId, questionId])
  @@index([questionId])
}

model TicketPayment {
  id                 String              @id @default(cuid())
  orderId            String
  provider           String
  providerCheckoutId String?
  providerPaymentId  String?
  idempotencyKey     String
  status             TicketPaymentStatus @default(CREATED)
  amountCents        Int
  currency           String              @default("EUR")
  checkoutUrl        String?
  providerStatus     String?
  expiresAt          DateTime?           @db.Timestamptz(3)
  succeededAt        DateTime?           @db.Timestamptz(3)
  failedAt           DateTime?           @db.Timestamptz(3)
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)

  order    TicketOrder            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  webhooks TicketPaymentWebhook[]
  refunds  TicketRefund[]

  @@unique([provider, providerCheckoutId])
  @@unique([provider, providerPaymentId])
  @@unique([provider, idempotencyKey])
  @@unique([id, orderId])
  @@index([orderId, status])
  @@index([status, expiresAt])
}

model TicketPaymentWebhook {
  id                 String    @id @default(cuid())
  provider           String
  externalEventId    String
  paymentId          String?
  signatureValid     Boolean
  payload            Json
  processingAttempts Int       @default(0)
  receivedAt         DateTime  @default(now()) @db.Timestamptz(3)
  processedAt        DateTime? @db.Timestamptz(3)
  lastError          String?

  payment TicketPayment? @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@unique([provider, externalEventId])
  @@index([paymentId])
  @@index([processedAt, receivedAt])
}

model Ticket {
  id                String       @id @default(cuid())
  eventId           String
  orderItemId       String       @unique
  publicCode        String       @unique
  credentialHash    String       @unique
  credentialVersion Int          @default(1)
  status            TicketStatus @default(VALID)
  issuedAt          DateTime     @default(now()) @db.Timestamptz(3)
  checkedInAt       DateTime?    @db.Timestamptz(3)
  checkedInById     String?
  voidedAt          DateTime?    @db.Timestamptz(3)
  refundedAt        DateTime?    @db.Timestamptz(3)

  event       TicketEvent     @relation(fields: [eventId], references: [id], onDelete: Restrict)
  orderItem   TicketOrderItem @relation(fields: [orderItemId, eventId], references: [id, eventId], onDelete: Restrict)
  checkedInBy User?           @relation("TicketCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)
  scanLogs    TicketScanLog[]

  @@unique([id, eventId])
  @@unique([orderItemId, eventId])
  @@index([eventId, status])
  @@index([eventId, checkedInAt])
  @@index([checkedInById])
}

model TicketRefund {
  id               String             @id @default(cuid())
  orderId          String
  paymentId        String
  provider         String
  providerRefundId String?
  idempotencyKey   String
  status           TicketRefundStatus @default(PENDING)
  amountCents      Int
  currency         String             @default("EUR")
  reason           String?
  requestedById    String?
  createdAt        DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(3)
  completedAt      DateTime?          @db.Timestamptz(3)

  order       TicketOrder        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment     TicketPayment      @relation(fields: [paymentId, orderId], references: [id, orderId], onDelete: Restrict)
  requestedBy User?              @relation("TicketRefundRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  items       TicketRefundItem[]

  @@unique([provider, providerRefundId])
  @@unique([provider, idempotencyKey])
  @@unique([id, orderId])
  @@index([orderId, status])
  @@index([paymentId])
  @@index([requestedById])
}

model TicketRefundItem {
  id          String @id @default(cuid())
  orderId     String
  refundId    String
  orderItemId String
  amountCents Int

  refund    TicketRefund    @relation(fields: [refundId, orderId], references: [id, orderId], onDelete: Restrict)
  orderItem TicketOrderItem @relation(fields: [orderItemId, orderId], references: [id, orderId], onDelete: Restrict)

  @@unique([refundId, orderItemId])
  @@index([orderItemId])
}

model TicketGate {
  id        String   @id @default(cuid())
  eventId   String
  code      String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  event    TicketEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scanLogs TicketScanLog[]

  @@unique([eventId, code])
  @@unique([id, eventId])
  @@index([eventId, active])
}

model TicketScanDevice {
  id          String    @id @default(cuid())
  eventId     String
  label       String
  tokenHash   String    @unique
  createdById String?
  lastSeenAt  DateTime? @db.Timestamptz(3)
  revokedAt   DateTime? @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)

  event     TicketEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("TicketScanDeviceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  scanLogs  TicketScanLog[]

  @@unique([id, eventId])
  @@index([eventId, revokedAt])
  @@index([createdById])
}

model TicketScanLog {
  id                    String           @id @default(cuid())
  eventId               String
  ticketId              String?
  scannerUserId         String?
  deviceId              String?
  gateId                String?
  clientScanId          String           @unique
  result                TicketScanResult
  credentialFingerprint String?
  scannedAt             DateTime         @default(now()) @db.Timestamptz(3)
  clientScannedAt       DateTime?        @db.Timestamptz(3)
  reversesScanId        String?          @unique
  metadata              Json?

  event        TicketEvent       @relation(fields: [eventId], references: [id], onDelete: Restrict)
  ticket       Ticket?           @relation(fields: [ticketId, eventId], references: [id, eventId], onDelete: Restrict)
  scannerUser  User?             @relation("TicketScanActor", fields: [scannerUserId], references: [id], onDelete: SetNull)
  device       TicketScanDevice? @relation(fields: [deviceId, eventId], references: [id, eventId], onDelete: Restrict)
  gate         TicketGate?       @relation(fields: [gateId, eventId], references: [id, eventId], onDelete: Restrict)
  reversesScan TicketScanLog?    @relation("TicketScanReversal", fields: [reversesScanId], references: [id], onDelete: Restrict)
  reversedBy   TicketScanLog?    @relation("TicketScanReversal")

  @@index([eventId, scannedAt])
  @@index([ticketId, scannedAt])
  @@index([scannerUserId])
  @@index([deviceId])
  @@index([gateId])
}

model TicketAuditLog {
  id          String   @id @default(cuid())
  eventId     String
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  event     TicketEvent @relation(fields: [eventId], references: [id], onDelete: Restrict)
  actorUser User?       @relation("TicketAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([eventId, entityType, entityId])
  @@index([actorUserId])
}

model TicketOutboxMessage {
  id          String             @id @default(cuid())
  eventId     String?
  orderId     String?
  type        String
  dedupeKey   String             @unique
  recipient   String?
  payload     Json
  status      TicketOutboxStatus @default(PENDING)
  attempts    Int                @default(0)
  availableAt DateTime           @default(now()) @db.Timestamptz(3)
  lockedAt    DateTime?          @db.Timestamptz(3)
  lockedBy    String?
  lastError   String?
  sentAt      DateTime?          @db.Timestamptz(3)
  createdAt   DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime           @updatedAt @db.Timestamptz(3)

  event TicketEvent? @relation(fields: [eventId], references: [id], onDelete: Restrict)
  order TicketOrder? @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([status, availableAt])
  @@index([eventId])
  @@index([orderId])
}

// -----------------------------------------------------------------------------
// Photo albums
// -----------------------------------------------------------------------------

model PhotoAlbum {
  id            String    @id @default(cuid())
  slug          String    @unique
  titleNl       String
  titleEn       String?
  descriptionNl String?
  descriptionEn String?
  coverPhotoId  String?   @unique
  eventDate     DateTime?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  coverPhoto Photo?  @relation("AlbumCover", fields: [coverPhotoId], references: [id], onDelete: SetNull)
  photos     Photo[] @relation("AlbumPhotos")
}

model Photo {
  id           String    @id @default(cuid())
  albumId      String
  storageKey   String
  thumbnailKey String?
  width        Int?
  height       Int?
  sizeBytes    Int?
  originalName String?
  takenAt      DateTime?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())

  album        PhotoAlbum  @relation("AlbumPhotos", fields: [albumId], references: [id], onDelete: Cascade)
  coverOfAlbum PhotoAlbum? @relation("AlbumCover")

  @@index([albumId])
}

// -----------------------------------------------------------------------------
// POCs (student representatives per study track)
// -----------------------------------------------------------------------------

model Poc {
  id            String  @id @default(cuid())
  slug          String  @unique
  nameNl        String
  nameEn        String?
  /// Eén adres voor de hele POC (bv. wtk-poc@vtk.be). Studenten mailen de POC,
  /// niet een individuele vertegenwoordiger; die adressen tonen we nergens.
  email         String?
  descriptionNl String?
  descriptionEn String?
  order         Int     @default(0)

  // Aan welke richtingen deze POC hangt. Dit is de enige koppeling met een
  // studierichting: het is de machineleesbare link naar `User.studyProgrammes`,
  // zodat de homepage de POC's van jouw richtingen kan tonen. Meerdere richtingen
  // per POC kan: één POC bedient soms verschillende opleidingen.
  studyProgrammes StudyProgramme[] @default([])

  representatives PocRepresentative[]
}

model PocRepresentative {
  id     String  @id @default(cuid())
  pocId  String
  userId String
  roleNl String?
  roleEn String?
  order  Int     @default(0)

  poc  Poc  @relation(fields: [pocId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pocId, userId])
}

// -----------------------------------------------------------------------------
// Partners
// -----------------------------------------------------------------------------

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoKey   String
  url       String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// Settings (key/value JSON, drives the editable homepage and opening hours)
// -----------------------------------------------------------------------------

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Admin dashboard tiles (configurable launchpad links)
// -----------------------------------------------------------------------------

model DashboardTile {
  id        String             @id @default(cuid())
  label     String
  url       String
  icon      String             @default("link") // key into curated icon set
  color     String             @default("navy") // key into color palette
  scope     DashboardTileScope
  groupId   String? // set when scope = GROUP
  userId    String? // set when scope = USER (personal tile)
  order     Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  group Group?                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prefs UserDashboardTilePref[]

  @@index([scope])
  @@index([groupId])
  @@index([userId])
}

// Per-user override of a shared (GLOBAL/GROUP) tile: hide it, reorder it, or
// override its display fields. Personal (USER) tiles are edited directly.
model UserDashboardTilePref {
  userId String
  tileId String
  hidden Boolean @default(false)
  order  Int?
  label  String? // null = inherit from the default tile
  url    String?
  icon   String?
  color  String?

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tile DashboardTile @relation(fields: [tileId], references: [id], onDelete: Cascade)

  @@id([userId, tileId])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// Shifts
// -----------------------------------------------------------------------------

model Shift {
  id String @id @default(cuid())

  participantIds Int[]
  participants   ShiftParticipant[]

  name            String
  startTime       DateTime
  endTime         DateTime
  location        String
  description     String
  maxParticipants Int
  reward          Int

  // Postcode (Group.code) waarvoor deze shift telt; los tekstveld i.p.v. een
  // relatie, zodat een oude postcode behouden blijft ook als de post later
  // gedeactiveerd of hernoemd wordt.
  post String?
  // Ook een field bijhouden voor het evenement waarbij de shift hoort?

  // Herkomst van een gespiegelde shift. Cursusdienst-shiften worden op
  // cudi.vtk.be aangemaakt en hierheen gespiegeld; `sourceSystem` ("cudi") +
  // `sourceId` (de cudi-shift-id) maken die spiegeling idempotent en markeren
  // dat main-admins ze niet manueel beheren. Native VTK-shiften laten beide
  // leeg (NULL, en NULLs botsen niet in de unieke index). Zie
  // docs/design-decisions.md, "Cursusdienst-shiften op de main site".
  sourceSystem String?
  sourceId     String?

  @@unique([sourceSystem, sourceId])
}

model ShiftParticipant {
  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // `payedOut` blijft de compatibele "volledig uitbetaald"-vlag voor bestaande
  // API-consumers. `rewardPaid` bewaart het exacte aantal toegekende bonnetjes,
  // zodat een shift ook gedeeltelijk kan worden uitbetaald.
  payedOut   Boolean
  rewardPaid Int     @default(0)

  /// Moment van inschrijven: binnen een korte bedenktijd mag je je nog
  /// uitschrijven, ook wanneer de shift al binnen 24 uur begint.
  registeredAt DateTime @default(now())

  @@id([shiftId, userId])
}

// -----------------------------------------------------------------------------
// Short links (on.vtk.be/<slug> -> target URL)
// -----------------------------------------------------------------------------

model ShortLink {
  id          String    @id @default(cuid())
  slug        String    @unique
  url         String
  enabled     Boolean   @default(true)
  clicks      Int       @default(0)
  note        String?
  expiresAt   DateTime? // when set, the link stops resolving after this instant
  createdById String?
  createdBy   User?     @relation("ShortLinkCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// -----------------------------------------------------------------------------
// Theokot (cafetaria / broodjesbar) reservatiesysteem
//
// Zie docs/design-decisions.md voor de niet-vanzelfsprekende keuzes achter dit
// systeem (bestelvenster, annulatie-deadline, no-show/ban-logica, turf-lijst,
// snapshots i.p.v. live catalogus).
// -----------------------------------------------------------------------------

/// Catalogus met het standaardaanbod. Prijs in eurocent (Int, geen floats).
/// Bij het aanmaken van een week worden deze rijen naar `TheokotSessionItem`
/// gekopieerd (snapshot), zodat latere catalogus-edits oude sessies niet wijzigen.
model TheokotProduct {
  id                  String   @id @default(cuid())
  nameNl              String
  nameEn              String?
  priceCents          Int
  defaultQuantity     Int      @default(0)
  isWeeklySpecialSlot Boolean  @default(false) // "broodje van de week"-slot
  order               Int      @default(0)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Eén verkoopsessie = één open dag. Uren en aanbod zijn per dag aanpasbaar;
/// `isOpen=false` betekent dat Theokot die dag dicht is. De venster-momenten
/// (order/pickup) worden bij aanmaak berekend uit config + Brussel-tijd en
/// opgeslagen zodat ze daarna manueel bijgesteld kunnen worden.
model TheokotSession {
  id                   String    @id @default(cuid())
  date                 DateTime  @unique // lokale middernacht van de verkoopdag
  isOpen               Boolean   @default(true)
  orderOpenAt          DateTime // vanaf wanneer studenten kunnen bestellen
  orderCloseAt         DateTime // annulatie-/besteldeadline (turf-lijst wordt geprint)
  pickupStart          DateTime
  pickupEnd            DateTime
  weeklySpecialLabelNl String? // welk broodje deze week "van de week" is
  weeklySpecialLabelEn String?
  processedAt          DateTime? // wanneer no-shows verwerkt zijn (idempotentie)
  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  items  TheokotSessionItem[]
  orders TheokotOrder[]

  @@index([date])
}

/// Aanbod van één sessie (snapshot van een product op het moment van aanmaken).
model TheokotSessionItem {
  id              String  @id @default(cuid())
  sessionId       String
  productId       String? // herkomst-catalogusitem, puur informatief
  nameNl          String
  nameEn          String?
  priceCents      Int
  quantity        Int // beschikbare voorraad voor deze sessie
  isWeeklySpecial Boolean @default(false)
  order           Int     @default(0)

  session TheokotSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lines   TheokotOrderLine[]

  @@index([sessionId])
}

/// Eén bestelling per persoon per sessie.
model TheokotOrder {
  id           String             @id @default(cuid())
  sessionId    String
  userId       String
  status       TheokotOrderStatus @default(RESERVED)
  totalCents   Int
  statusNote   String? // vrije notitie bij correcties
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  pickedUpAt   DateTime?
  pickedUpById String? // wie aan de balie op "opgehaald" drukte

  session           TheokotSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user              User                      @relation("TheokotOrderUser", fields: [userId], references: [id], onDelete: Cascade)
  pickedUpBy        User?                     @relation("TheokotPickedUpBy", fields: [pickedUpById], references: [id], onDelete: SetNull)
  lines             TheokotOrderLine[]
  voucherRedemption TheokotVoucherRedemption?

  @@unique([sessionId, userId])
  @@index([userId])
  @@index([status])
}

/// Auditrij wanneer een student aan de afhaalbalie twee nog openstaande
/// medewerkersbonnetjes gebruikt voor een broodje.
model TheokotVoucherRedemption {
  id            String   @id @default(cuid())
  orderId       String   @unique
  userId        String
  processedById String?
  amount        Int      @default(2)
  createdAt     DateTime @default(now())

  order       TheokotOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user        User         @relation("TheokotVoucherUser", fields: [userId], references: [id], onDelete: Cascade)
  processedBy User?        @relation("TheokotVoucherProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model TheokotOrderLine {
  id             String @id @default(cuid())
  orderId        String
  sessionItemId  String
  quantity       Int
  unitPriceCents Int // snapshot van de prijs op besteldatum

  order       TheokotOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sessionItem TheokotSessionItem @relation(fields: [sessionItemId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([sessionItemId])
}

/// Tijdelijke ban na te veel no-shows. Historiek blijft bewaard; een ban
/// opheffen zet `active=false` (i.p.v. verwijderen) zodat correcties zichtbaar blijven.
model TheokotBan {
  id          String   @id @default(cuid())
  userId      String
  reason      String
  startsAt    DateTime @default(now())
  endsAt      DateTime
  active      Boolean  @default(true)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

// -----------------------------------------------------------------------------
// Uitleendienst (logistiek.vtk.be): materiaal lenen, transport (kar/auto/
// bakfiets) en flesserke. Aanvragen gebeuren per evenement, met een
// aanvragertype (intern/werkgroep/extern). Flow: lid vraagt aan (REQUESTED),
// Logistiek keurt goed of wijst af; de harde voorraadcheck gebeurt bij
// goedkeuring in een Serializable-transactie. Prijzen/waarborgen worden
// gesnapshot zodat catalogswijzigingen bestaande reservaties niet herschrijven.
// -----------------------------------------------------------------------------

model UitleenCategory {
  id        String   @id @default(cuid())
  name      String
  sortIndex Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items UitleenItem[]
}

model UitleenItem {
  id           String  @id @default(cuid())
  categoryId   String?
  name         String
  description  String?
  photoKey     String?
  // Aantal fysieke exemplaren; beschikbaarheid = quantity min overlappende
  // APPROVED/PICKED_UP-reservaties in de gevraagde periode.
  quantity     Int     @default(1)
  depositCents Int     @default(0) // waarborg per stuk
  priceCents   Int     @default(0) // huurprijs per stuk per reservatie; 0 = gratis
  active       Boolean @default(true) // soft-delete: uit de catalogus, historiek blijft

  // Een set is een fysiek samengestelde bundel met eigen voorraad; de inhoud
  // (setContents) is louter beschrijvend en koppelt niet aan andere items.
  isSet Boolean @default(false)

  // Locatie in de loods (schap/rek) en staat; puur informatief voor het team.
  locationShelf String? // bv. "2R"
  locationRack  String? // bv. "A1"
  condition     UitleenItemCondition @default(WERKT)
  conditionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category    UitleenCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  lines       UitleenReservationLine[]
  setContents UitleenSetContent[]

  @@index([categoryId, active])
}

/// Beschrijvende inhoud van een set (vrije tekst, geen koppeling aan andere
/// items zodat de voorraad niet dubbel geteld wordt).
model UitleenSetContent {
  id        String @id @default(cuid())
  itemId    String
  label     String
  quantity  Int    @default(1)
  sortIndex Int    @default(0)

  item UitleenItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortIndex])
}

model UitleenReservation {
  id     String                   @id @default(cuid())
  userId String
  status UitleenReservationStatus @default(REQUESTED)

  // Namens wie de aanvraag gebeurt. INTERN koppelt aan een post (groupId);
  // WERKGROEP/EXTERN bewaren een vrije naam (requesterName).
  requesterType UitleenRequesterType @default(INTERN)
  groupId       String?
  requesterName String?

  // Evenement-context (de Logi-werking vraagt aan per evenement).
  eventName          String // verplicht: waarvoor het materiaal dient
  eventLocation      String?
  eventStart         DateTime? @db.Timestamptz(3) // startuur (opbouw) van het evenement
  expectedAttendance Int?
  contactName        String?
  contactPhone       String?
  delivery           Boolean   @default(false) // levering nodig?
  deliveryNote       String?

  // Afhaal- en terugbrengdag (hele dagen; de concrete uren spreekt het team af).
  pickupDate DateTime @db.Date
  returnDate DateTime @db.Date

  memberNote String? // extra info van het lid
  adminNote  String? // nota van het team (bv. reden van afwijzing)

  // Totalen gesnapshot bij de aanvraag.
  totalPriceCents   Int
  totalDepositCents Int

  paymentMode       UitleenPaymentMode? // gezet door het team bij goedkeuring
  paidOfflineAt     DateTime? // team drukte "betaald bij afhaling"
  depositReturnedAt DateTime?

  decidedAt    DateTime?
  decidedById  String?
  pickedUpAt   DateTime?
  pickedUpById String?
  returnedAt   DateTime?
  returnedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User   @relation("UitleenReservationUser", fields: [userId], references: [id], onDelete: Cascade)
  group      Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  decidedBy  User?  @relation("UitleenDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  pickedUpBy User?  @relation("UitleenPickedUpBy", fields: [pickedUpById], references: [id], onDelete: SetNull)
  returnedBy User?  @relation("UitleenReturnedBy", fields: [returnedById], references: [id], onDelete: SetNull)

  lines          UitleenReservationLine[]
  flesserkeLines UitleenFlesserkeLine[]
  payments       UitleenPayment[]

  @@index([userId])
  @@index([status, pickupDate])
  @@index([pickupDate, returnDate])
  @@index([requesterType, status])
}

model UitleenReservationLine {
  id            String @id @default(cuid())
  reservationId String
  itemId        String

  // Snapshot van het item op aanvraagmoment.
  itemName         String
  quantity         Int
  unitPriceCents   Int
  unitDepositCents Int

  reservation UitleenReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  // Items worden soft-deleted (active=false), nooit hard verwijderd zolang er
  // reservaties aan hangen.
  item        UitleenItem        @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([reservationId])
  @@index([itemId])
}

/// Een voertuig van de transportdienst (kar, auto, bakfiets). Tarieven zijn
/// team-configureerbaar, daarom DB-rijen i.p.v. een enum.
model UitleenVehicle {
  id          String             @id @default(cuid())
  code        String             @unique // kar | auto | bakfiets
  nameNl      String
  nameEn      String
  description String?
  pricingMode UitleenPricingMode @default(FREE)
  rateCents   Int                @default(0) // per uur / per km / vast, naargelang pricingMode
  sortIndex   Int                @default(0)
  active      Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings UitleenTransportBooking[]
}

/// Transportaanvraag met een voertuig, een tijdvenster en (later) een chauffeur.
/// Bewust een eigen model (geen materiaalaanvraag): aparte behandelaar, aparte
/// lifecycle. Prijs kan pas bij afronden gekend zijn (per-km).
model UitleenTransportBooking {
  id        String                        @id @default(cuid())
  userId    String
  vehicleId String
  status    UitleenTransportBookingStatus @default(REQUESTED)

  requesterType UitleenRequesterType @default(INTERN)
  groupId       String?
  requesterName String?

  startAt DateTime @db.Timestamptz(3)
  endAt   DateTime @db.Timestamptz(3)

  eventName     String? // vrije koppeling aan het evenement (geen FK)
  purpose       String // waarvoor de rit dient
  pickupAddress String?
  destination   String?
  helpersNote   String? // bijrijders die de aanvrager zelf voorziet

  driverId String? // pas het weekend ervoor toegewezen; blijft optioneel bij goedkeuring

  // Tarief gesnapshot bij de aanvraag (en her-gesnapshot bij een voertuigwissel).
  pricingMode UitleenPricingMode
  rateCents   Int
  kilometers  Int? // ingevuld bij afronden voor PER_KM
  priceCents  Int? // null = nog niet gekend (PER_KM voor de rit)

  paymentMode   UitleenPaymentMode?
  paidOfflineAt DateTime?

  memberNote String?
  adminNote  String?

  decidedAt     DateTime?
  decidedById   String?
  completedAt   DateTime?
  completedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User           @relation("UitleenTransportUser", fields: [userId], references: [id], onDelete: Cascade)
  vehicle     UitleenVehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  group       Group?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  driver      User?          @relation("UitleenTransportDriver", fields: [driverId], references: [id], onDelete: SetNull)
  decidedBy   User?          @relation("UitleenTransportDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  completedBy User?          @relation("UitleenTransportCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  payments UitleenPayment[]

  @@index([userId])
  @@index([status, startAt])
  @@index([startAt, endAt])
  @@index([vehicleId, status])
  @@index([requesterType, status])
}

/// Spiegel van TicketPayment (zonder refunds): provider is een vrije string
/// zodat een providerwissel geen migratie vraagt. Precies één van
/// reservationId/transportBookingId is gezet.
model UitleenPayment {
  id                 String               @id @default(cuid())
  reservationId      String?
  transportBookingId String?
  provider           String
  providerCheckoutId String?
  providerPaymentId  String?
  idempotencyKey     String
  status             UitleenPaymentStatus @default(CREATED)
  amountCents        Int
  currency           String               @default("EUR")
  checkoutUrl        String?
  providerStatus     String?
  expiresAt          DateTime?            @db.Timestamptz(3)
  succeededAt        DateTime?            @db.Timestamptz(3)
  failedAt           DateTime?            @db.Timestamptz(3)
  createdAt          DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime             @updatedAt @db.Timestamptz(3)

  reservation      UitleenReservation?      @relation(fields: [reservationId], references: [id], onDelete: Restrict)
  transportBooking UitleenTransportBooking? @relation(fields: [transportBookingId], references: [id], onDelete: Restrict)
  webhooks         UitleenPaymentWebhook[]

  @@unique([provider, providerCheckoutId])
  @@unique([provider, providerPaymentId])
  @@unique([provider, idempotencyKey])
  @@index([reservationId, status])
  @@index([transportBookingId, status])
  @@index([status, expiresAt])
}

model UitleenPaymentWebhook {
  id                 String    @id @default(cuid())
  provider           String
  externalEventId    String
  paymentId          String?
  signatureValid     Boolean
  payload            Json
  processingAttempts Int       @default(0)
  receivedAt         DateTime  @default(now()) @db.Timestamptz(3)
  processedAt        DateTime? @db.Timestamptz(3)
  lastError          String?

  payment UitleenPayment? @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@unique([provider, externalEventId])
  @@index([paymentId])
  @@index([processedAt, receivedAt])
}

// -----------------------------------------------------------------------------
// Flesserke: verbruiksstock (voeding, drank, huishoudproducten) die per event
// wordt klaargezet. Enkel voor interne werking (INTERN/WERKGROEP). Beschikbaar
// wordt altijd berekend (quantity min gereserveerd), nooit opgeslagen. Bij het
// terugbrengen boekt het team het verbruik af (gesloten terug, open weg).
// -----------------------------------------------------------------------------

model UitleenFlesserkeCategory {
  id        String   @id @default(cuid())
  name      String
  sortIndex Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items UitleenFlesserkeItem[]
}

model UitleenFlesserkeItem {
  id            String    @id @default(cuid())
  categoryId    String?
  name          String
  brand         String?
  contentAmount String? // "Hoeveelheid [kg of L]"
  expiryDate    DateTime? @db.Date // eerste vervaldatum
  colruytUrl    String?
  quantity      Int       @default(0) // fysieke voorraad; beschikbaar = quantity - gereserveerd
  locationShelf String?
  locationRack  String?
  note          String?
  active        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category UitleenFlesserkeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  lines    UitleenFlesserkeLine[]

  @@index([categoryId, active])
}

model UitleenFlesserkeLine {
  id              String @id @default(cuid())
  reservationId   String
  flesserkeItemId String

  itemName         String // snapshot
  quantity         Int
  returnedQuantity Int? // ingevuld bij terugbrengen; verbruik = quantity - returnedQuantity

  reservation UitleenReservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  item        UitleenFlesserkeItem @relation(fields: [flesserkeItemId], references: [id], onDelete: Restrict)

  @@index([reservationId])
  @@index([flesserkeItemId])
}

// -----------------------------------------------------------------------------
// Deurtoegang (KU Leuven-kaartscanner op de deur, bediend door een Raspberry Pi)
// -----------------------------------------------------------------------------

// Tijdelijke deurtoegang los van de rollen: wie geen `door.open`-recht heeft maar
// binnen [startsAt, endsAt] valt, mag de deur toch openen. Bedoeld voor gasten,
// externen of kortlopende uitzonderingen. Verlopen grants blijven staan als
// historiek; ze tellen enkel mee zolang now in het venster valt.
model DoorAccessGrant {
  id          String   @id @default(cuid())
  userId      String
  startsAt    DateTime @default(now())
  endsAt      DateTime
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([endsAt])
}

// Eén rij per deurgebeurtenis: elke kaartscan (toegelaten, geweigerd, onbekende
// kaart of fout) en elke remote-open vanaf het dashboard. Voedt de statistiek en
// het logoverzicht in /admin/deur. `userId` is null wanneer de kaart niet aan een
// gebruiker gekoppeld kon worden; `offline` markeert events die de Pi tijdens een
// outage bufferde en later naflushte.
model DoorAccessLog {
  id       String        @id @default(cuid())
  at       DateTime      @default(now())
  userId   String?
  rNumber  String?
  cardName String?
  method   DoorMethod
  result   DoorLogResult
  reason   String?
  offline  Boolean       @default(false)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([at])
  @@index([result])
  @@index([userId])
}

// Persoonlijk, intrekbaar token waarmee een Apple Shortcut de deur via de
// publieke website-API kan openen. Alleen de SHA-256-hash wordt bewaard; het
// ruwe token wordt bij aanmaak exact één keer aan de gebruiker getoond.
model DoorShortcutToken {
  id         String    @id @default(cuid())
  userId     String
  label      String
  tokenHash  String    @unique
  expiresAt  DateTime  @db.Timestamptz(3)
  lastUsedAt DateTime? @db.Timestamptz(3)
  revokedAt  DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

// -----------------------------------------------------------------------------
// KU Leuven SSO (OIDC) debug log
// -----------------------------------------------------------------------------
// Opt-in via Admin -> IT (Setting-sleutel "kul.debug"). Eén rij per KU Leuven-
// login met de ruwe claims die better-auth aan `mapProfileToUser` doorgeeft,
// zodat een superadmin kan zien welke attributen ICTS effectief vrijgeeft (bv. of
// KULeuvenEmployeeType/faculteit binnenkomt). Bevat persoonsgegevens, staat
// daarom standaard uit en wordt tot de laatste N rijen gesnoeid.
model KulAuthLog {
  id      String   @id @default(cuid())
  at      DateTime @default(now())
  email   String?
  rNumber String?
  claims  Json

  @@index([at])
}

// -----------------------------------------------------------------------------
// better-auth specific tables
// -----------------------------------------------------------------------------

model Session {
  id                 String              @id
  token              String
  expiresAt          DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  ipAddress          String?
  userAgent          String?
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthRefreshTokens OauthRefreshToken[]
  oauthAccessTokens  OauthAccessToken[]

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

//JWT plugin
model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime  @db.Timestamptz(3)
  expiresAt  DateTime? @db.Timestamptz(3)

  @@map("jwks")
}

//SSO-provider
model OauthClient {
  id                      String              @id
  clientId                String              @unique
  clientSecret            String?
  disabled                Boolean?
  skipConsent             Boolean?
  enableEndSession        Boolean?
  subjectType             String?
  scopes                  String[]
  user                    User?               @relation(fields: [userId], references: [id])
  userId                  String?
  referenceId             String?
  createdAt               DateTime?           @db.Timestamptz(3)
  updatedAt               DateTime?           @db.Timestamptz(3)
  name                    String?
  uri                     String?
  icon                    String?
  contacts                String[]
  tos                     String?
  policy                  String?
  softwareId              String?
  softwareVersion         String?
  softwareStatement       String?
  redirectUris            String[]
  postLogoutRedirectUris  String[]
  tokenEndpointAuthMethod String?
  grantTypes              String[]
  responseTypes           String[]
  public                  Boolean?
  type                    String?
  requirePKCE             Boolean?
  metadata                Json?

  /// Wie hier mag inloggen; zie SsoAccessMode. Staat bewust op deze tabel en
  /// niet in een aparte VTK-tabel: de poort draait op het hete pad van élke
  /// autorisatie en moet zonder join te beantwoorden zijn. De plugin negeert
  /// kolommen die ze niet kent.
  accessMode              SsoAccessMode       @default(OPEN)
  /// Prefix waarop de permissiecodes van deze client gevalideerd worden
  /// ("wiki" -> wiki.read, wiki.access). Null zolang er geen vocabulaire is.
  permissionNamespace     String?

  oauthRefreshTokens      OauthRefreshToken[]
  oauthAccessTokens       OauthAccessToken[]
  oauthConsents           OauthConsent[]
  clientPermissions       SsoClientPermission[]

  @@map("oauthClient")
}

/// Het permissievocabulaire dat één client zelf definieert (`wiki.read`,
/// `cudi.admin`). Bewust géén VTK-permissies: dit zegt wat een lid mag binnen
/// die ene applicatie, niet wat het binnen VTK mag.
model SsoClientPermission {
  id       String      @id @default(cuid())
  client   OauthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  clientId String

  code          String
  labelNl       String
  labelEn       String
  descriptionNl String?
  descriptionEn String?

  /// De `<namespace>.access`-rij die toegang verleent tot een RESTRICTED client.
  /// Wordt automatisch aangemaakt en mag niet verwijderd worden zolang de client
  /// beperkt is: ze weghalen sluit iedereen buiten.
  system Boolean @default(false)
  /// Verbergt de code in toekenningsformulieren maar laat bestaande
  /// toekenningen werken. Veiliger dan verwijderen; zie ontwerp 9.7.
  deprecated Boolean @default(false)

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userGrants  SsoUserClientPermission[]
  roleGrants  SsoRoleClientPermission[]
  groupGrants SsoGroupClientPermission[]

  @@unique([clientId, code])
  @@index([clientId, deprecated])
}

/// Directe toekenning aan één lid. Deze reset NIET op 15 juli: een grant aan de
/// ene persoon die een integratie onderhoudt is geen werkingsjaar-begrip, en
/// elke partnertoepassing 's nachts leegmaken is een storing die niemand zag
/// aankomen. Gebruik `expiresAt` voor wat wél tijdelijk is. Zie ontwerp 9.5.
model SsoUserClientPermission {
  id           String              @id @default(cuid())
  permission   SsoClientPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String
  /// Gedenormaliseerd zodat de hete query (userId + clientId) één indexlookup is.
  clientId     String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String

  grantedByUserId String?
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime?
  note            String?

  @@unique([permissionId, userId])
  @@index([userId, clientId])
  @@index([clientId])
  @@index([expiresAt])
}

/// Toekenning via een VTK-rol. Werkingsjaar-gescoped via UserRole, dus deze
/// erft de 15-juli-reset.
model SsoRoleClientPermission {
  id           String              @id @default(cuid())
  permission   SsoClientPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String
  clientId     String
  role         Role                @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String

  grantedByUserId String?
  grantedAt       DateTime @default(now())

  @@unique([permissionId, roleId])
  @@index([roleId, clientId])
}

/// Toekenning via een post. LEADER geldt enkel voor de verantwoordelijke,
/// exact zoals GroupRole dat voor rollen doet. Ook werkingsjaar-gescoped.
model SsoGroupClientPermission {
  id           String              @id @default(cuid())
  permission   SsoClientPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String
  clientId     String
  group        Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String
  kind         RoleGrantKind       @default(DEFAULT)

  grantedByUserId String?
  grantedAt       DateTime @default(now())

  @@unique([permissionId, groupId, kind])
  @@index([groupId, clientId])
}

model OauthRefreshToken {
  id                String             @id
  token             String             @unique
  client            OauthClient        @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  clientId          String
  session           Session?           @relation(fields: [sessionId], references: [id])
  sessionId         String?
  user              User               @relation(fields: [userId], references: [id])
  userId            String
  referenceId       String?
  scopes            String[]
  revoked           DateTime?          @db.Timestamptz(3)
  authTime          DateTime?          @db.Timestamptz(3)
  createdAt         DateTime           @db.Timestamptz(3)
  expiresAt         DateTime           @db.Timestamptz(3)
  oauthAccessTokens OauthAccessToken[]

  // De plugin declareert deze indexen wel, de Prisma-modellen droegen ze niet.
  // Ze bedienen de hete paden: token-uitwisseling zoekt op clientId/userId, en
  // de opkuis van verlopen tokens scant op expiresAt.
  @@index([clientId])
  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("oauthRefreshToken")
}

model OauthAccessToken {
  id          String             @id
  token       String             @unique
  client      OauthClient        @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  clientId    String
  session     Session?           @relation(fields: [sessionId], references: [id])
  sessionId   String?
  refresh     OauthRefreshToken? @relation(fields: [refreshId], references: [id], onDelete: SetNull)
  refreshId   String?
  user        User?              @relation(fields: [userId], references: [id])
  userId      String?
  referenceId String?
  scopes      String[]
  createdAt   DateTime           @db.Timestamptz(3)
  expiresAt   DateTime           @db.Timestamptz(3)

  @@index([clientId])
  @@index([userId])
  @@index([sessionId])
  @@index([refreshId])
  @@index([expiresAt])
  @@map("oauthAccessToken")
}

model OauthConsent {
  id          String      @id
  user        User        @relation(fields: [userId], references: [id])
  userId      String
  client      OauthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  clientId    String
  referenceId String?
  scopes      String[]
  createdAt   DateTime    @db.Timestamptz(3)
  updatedAt   DateTime    @db.Timestamptz(3)

  // De uniciteit van een toestemming (clientId, userId, referenceId) staat NIET
  // hier maar als expressie-index in de migratie: Postgres beschouwt NULL's als
  // onderling verschillend, dus een gewone @@unique zou net het courante geval
  // (referenceId IS NULL) ongemoeid laten en duplicaten toelaten. De migratie
  // gebruikt COALESCE("referenceId",'').
  @@index([clientId])
  @@index([userId])
  @@map("oauthConsent")
}

/// Wie heeft wat gewijzigd aan welke OAuth-client. Bewust geen veld-diffs: het
/// SSO-team is klein, en de vraag is in de praktijk "wie zette dit aan en
/// wanneer", niet "welke byte veranderde".
///
/// Deze log is de enige verantwoording die er is: iedereen met
/// `oauth.client.edit` mag elke client bewerken, dus er is geen eigenaar of
/// fijnmazig recht dat een wijziging nog tegenhoudt.
model SsoAuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorId String?
  /// Naam op het moment van de actie. Los van de relatie, zodat de regel
  /// leesbaar blijft nadat het lid verwijderd is.
  actorName String

  /// Geen relatie naar OauthClient: een verwijderde client moet juist in de log
  /// blijven staan, en een FK zou die regel mee weggooien of het verwijderen
  /// blokkeren.
  clientId   String
  clientName String

  /// create | update | rotate-secret | enable | disable | delete | revoke-tokens
  action String
  /// Korte, leesbare samenvatting, bv. "redirect-URI's gewijzigd".
  summary String?

  @@index([createdAt])
  @@index([clientId])
  @@map("ssoAuditLog")
}
