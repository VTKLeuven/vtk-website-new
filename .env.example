# Copy to .env (at repo root) and fill in.

# Postgres
DATABASE_URL="postgresql://vtk:vtk@localhost:5432/vtk?schema=public"
POSTGRES_USER="vtk"
POSTGRES_PASSWORD="vtk"
POSTGRES_DB="vtk"

# Session cookie that is shared across subdomains. Use ".vtk.be" in production.
SESSION_COOKIE_DOMAIN=""

# Base URL of the main web app. Used by submodules to verify sessions remotely.
VTK_MAIN_URL="http://localhost:3000"

# S3 object storage.
# Preferably configured at runtime via Admin -> IT (stored in the DB, secret
# encrypted). These env vars are only a FALLBACK until that is filled in, and
# are handy for local dev. S3_FORCE_PATH_STYLE="false" switches to
# virtual-hosted-style URLs (bucket as subdomain); path-style is the default.
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="vtk"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"

# Optional: create a first superadmin on `npm run db:seed`.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# The web container runs `prisma migrate deploy` on every start, but only runs
# the seed when RUN_SEED=true. Leave it unset/false in normal operation so a
# redeploy never re-asserts seeded content over edits made in /admin. Set it to
# "true" for a single start to initialise a fresh DB, then remove it again.
RUN_SEED=""

# SMTP for transactional mail (o.a. Theokot no-show-waarschuwingen). Laat SMTP_HOST
# leeg om mails enkel te loggen i.p.v. te versturen (handig lokaal).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Theokot VTK <theokot@vtk.be>"

# Better auth variables
# openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-me-with-a-secret"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"
BETTER_AUTH_COOKIE_DOMAIN=".vtk.be"

# KU Leuven SSO (OpenID Connect). Leave blank to disable the "Sign in with
# KU Leuven" button and run with email/password only. KU Leuven uses the
# Shibboleth OIDC OP of the Associatie KU Leuven, so the discovery URL is the
# Shibboleth issuer (ICTS gives you the exact value), e.g.
#   https://idp.kuleuven.be/.well-known/openid-configuration
KUL_OIDC_DISCOVERY_URL=""
# KUL_OIDC_CLIENT_ID is also the "Entity ID" you enter in the Shibboleth tool.
# It is a stable identifier and should stay the same across deployments.
KUL_OIDC_CLIENT_ID=""
KUL_OIDC_CLIENT_SECRET=""
# The redirect/callback URI is derived automatically from BETTER_AUTH_URL as
#   <BETTER_AUTH_URL>/api/auth/better/oauth2/callback/kuleuven
# Only set this to override it. Visit /sso-metadata (as superadmin) to see the
# exact values to register for the current deployment.
KUL_OIDC_REDIRECT_URI=""

# Integrated ticketing. Development defaults to the built-in mock provider;
# production must use `mollie` and a real API key.
TICKETING_PAYMENT_PROVIDER="mock"
TICKETING_PUBLIC_URL="http://localhost:3000"
TICKETING_RESERVATION_MINUTES="31"
# Generate each independently with `openssl rand -base64 48` before production.
TICKETING_TOKEN_SECRET=""
TICKETING_MAINTENANCE_SECRET=""
# Mollie payment provider. Use a `test_...` key for development/staging and a
# `live_...` key in production. The webhook is served at
# <TICKETING_PUBLIC_URL>/api/tickets/mollie/webhook and must be publicly
# reachable (Mollie rejects localhost); it is skipped automatically when
# TICKETING_PUBLIC_URL points at localhost.
MOLLIE_API_KEY=""

# SMTP used by the durable ticket mail outbox. In development, messages are
# logged when SMTP_HOST is empty.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
MAIL_FROM="VTK Tickets <tickets@vtk.be>"
MAIL_REPLY_TO="info@vtk.be"

# KU Leuven kaartverificatie (Theokot-afhaalbalie: studentenkaart scannen).
# APARTE client-credentials van de OIDC-login hierboven — dit zijn de credentials
# voor de idverification-API (account.kuleuven.be). Laat leeg om enkel het
# handmatige r-nummerveld te gebruiken; de scanknop geeft dan een nette foutmelding.
KUL_CARD_CLIENT_ID=""
KUL_CARD_CLIENT_SECRET=""
# Optioneel: overschrijf de standaard-endpoints (defaults zijn de KU Leuven-productie).
KUL_CARD_AUTH_ENDPOINT="https://idp.kuleuven.be/auth/realms/kuleuven/protocol/openid-connect/token"
KUL_CARD_ID_ENDPOINT="https://account.kuleuven.be/api/v1/idverification"

# Sentry (error monitoring / tracing / session replay voor apps/web).
# De DSN kun je nu beheren via Admin -> IT (in de DB); deze env-DSN's zijn enkel
# nog een FALLBACK. Laat alles leeg om Sentry uit te schakelen (SDK blijft inert).
NEXT_PUBLIC_SENTRY_DSN=""   # publiek; gebruikt in de browser (fallback)
SENTRY_DSN=""              # server/edge (fallback; mag dezelfde DSN zijn)
# BLIJVEN in .env: alleen nodig voor source-map-upload bij `next build`. Dit is
# build-time en kan niet naar een runtime-instelling (de build draait voor de DB
# bestaat). SENTRY_AUTH_TOKEN is het gevoelige, build-time secret.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
