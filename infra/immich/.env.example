# Immich storage
UPLOAD_LOCATION=./data/library
DB_DATA_LOCATION=./data/postgres
TZ=Europe/Brussels

# Immich release. Pin to a concrete release for repeatable upgrades.
IMMICH_VERSION=v3.0.1

# Local database credentials. Keep this alphanumeric for Docker/Postgres parsing.
DB_PASSWORD=ImmichPortfolio123
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Local URLs used by the seed script.
IMMICH_URL=http://localhost:2283
PUBLIC_PROXY_URL=http://localhost:3001
PUBLIC_PROXY_PORT=3001

# First-run local admin for Immich.
IMMICH_ADMIN_EMAIL=portfolio@example.test
IMMICH_ADMIN_PASSWORD=ImmichPortfolio123
IMMICH_ADMIN_NAME="Immich Admin"

# Gallery service. Create an Immich API key in the Immich UI and paste it into .env.
GALLERY_IMMICH_API_URL=http://immich-server:2283/api
GALLERY_IMMICH_API_KEY=
GALLERY_PUBLIC_PROXY_URL=http://localhost:3001
GALLERY_ALBUM_MARKER=[gallery]
GALLERY_CACHE_TTL_SECONDS=60

# Face search uses Immich's local Postgres face embeddings.
GALLERY_DATABASE_HOST=database
GALLERY_DATABASE_PORT=5432
GALLERY_DATABASE_NAME=immich
GALLERY_DATABASE_USER=postgres
GALLERY_DATABASE_PASSWORD=ImmichPortfolio123
GALLERY_FACE_SEARCH_ENABLED=true
GALLERY_FACE_SEARCH_MAX_UPLOAD_BYTES=8388608
GALLERY_FACE_SEARCH_TIMEOUT_SECONDS=240
GALLERY_FACE_SEARCH_POLL_INTERVAL_MS=2500
GALLERY_FACE_SEARCH_MAX_JOBS=50
GALLERY_FACE_SEARCH_MIN_FACE_AREA_RATIO=0.008
GALLERY_FACE_SEARCH_DOMINANT_FACE_AREA_RATIO=2.2
GALLERY_FACE_MATCH_MAX_DISTANCE=0.42
GALLERY_FACE_MATCH_MAX_RESULTS=80
