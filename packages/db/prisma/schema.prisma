// VTK website Prisma schema.
// Generated client lands in @vtk/db/node_modules/.prisma/client for each package.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum Locale {
  NL
  EN
}

enum MembershipRole {
  MEMBER
  LEAD
}

// Hoe een post (Group) een rol toekent aan haar leden.
// DEFAULT: elk lid van de post krijgt de rol. LEADER: enkel de
// verantwoordelijke (membership.role == LEAD) krijgt de rol, bovenop de
// DEFAULT-rollen van de post.
enum RoleGrantKind {
  DEFAULT
  LEADER
}

enum PageAssetKind {
  EMBEDDED_PDF
  DOWNLOAD
}

enum EventVisibility {
  PUBLIC
  MEMBERS
}

enum DashboardTileScope {
  GLOBAL
  GROUP
  USER
}

enum TicketEventStatus {
  DRAFT
  PUBLISHED
  SALES_PAUSED
  SALES_CLOSED
  CANCELLED
  ARCHIVED
}

enum TicketAudience {
  PUBLIC
  MEMBERS
}

enum TicketQuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  BOOLEAN
}

enum TicketGrantRole {
  OWNER
  MANAGER
  FINANCE
  SCANNER
  REPORTER
}

enum TicketGroupGrantScope {
  ALL_MEMBERS
  LEADS_ONLY
}

enum TicketOrderStatus {
  PENDING_PAYMENT
  PAID
  PAYMENT_FAILED
  EXPIRED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum TicketPaymentStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum TicketRefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum TicketStatus {
  VALID
  VOID
  REFUNDED
}

enum TicketScanResult {
  ACCEPTED
  ALREADY_USED
  WRONG_EVENT
  INVALID
  VOID
  REFUNDED
  EXPIRED
  REVERSED
}

enum TicketOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DEAD
}

enum TheokotOrderStatus {
  RESERVED // gereserveerd, nog niet opgehaald
  PICKED_UP // afgehaald aan de balie
  NO_SHOW // niet opgehaald na sluitingstijd + grace
  CANCELLED // door de student geannuleerd voor de deadline
}

// Welk e-mailadres de kring gebruikt om een lid te contacteren.
enum EmailPreference {
  UNIVERSITY // universiteitsmail (= login-mail via KUL SSO)
  PERSONAL // persoonlijke mail
}

// Mailinglijst-categorieën waarvoor een lid zich (opt-in) kan inschrijven.
enum MailCategory {
  FEEST
  CAREER
  SPORT
  EVENEMENTEN
  ONDERWIJS
  INTERNATIONAAL
  EERSTEJAARS
  BAKSKE
}

// In welk studiejaar een lid zit.
enum StudyYear {
  BACHELOR_1
  BACHELOR_2
  BACHELOR_3
  MASTER_1
  MASTER_2
}

// Studierichtingen (een lid kan er meerdere aanduiden). Labels (NL/EN) leven in
// de i18n-dictionaries, niet in de enum.
enum StudyProgramme {
  ARCHITECTURE
  BIOMEDICAL
  COMMON_BACHELOR
  CIVIL
  CHEMICAL
  COMPUTER_SCIENCE
  CYBERSECURITY
  DIGITAL_HUMANITIES
  ELECTRICAL
  ENERGY
  ARTIFICIAL_INTELLIGENCE
  MATERIALS
  NANO
  URBANISM
  MATHEMATICAL
  MECHANICAL
}

// -----------------------------------------------------------------------------
// Users, groups, permissions
// -----------------------------------------------------------------------------

model User {
  id            String  @id @default(cuid())
  // `name` blijft de weergavenaam (en het veld dat better-auth zelf zet bij een
  // SSO-login). `firstName`/`lastName` zijn de gestructureerde variant die de
  // mailinglijst-exports nodig hebben; ze worden ingevuld tijdens de onboarding
  // en in het gebruikersbeheer, en `name` wordt daaruit samengesteld.
  name          String
  firstName     String?
  lastName      String?
  email         String  @unique
  rNumber       String? @unique // KU Leuven studentennummer (bvb r0123456), voor zoeken
  emailVerified Boolean @default(false)
  avatarKey     String?
  image         String?

  locale       Locale  @default(NL)
  active       Boolean @default(true)
  isSuperAdmin Boolean @default(false)

  // Onboarding-profiel (ingevuld bij de eerste KUL SSO-login). Zolang
  // onboardedAt null is, wordt het lid naar de onboarding-flow gestuurd.
  onboardedAt        DateTime?
  // Kotadres
  street             String?
  houseNumber        String?
  bus                String? // busnummer, optioneel
  postalCode         String?
  city               String?
  birthDate          DateTime?
  // Contact: `email` is de login-/universiteitsmail (via SSO). Persoonlijke
  // mail en de voorkeur voor communicatie komen erbij.
  personalEmail      String?
  emailPreference    EmailPreference  @default(UNIVERSITY)
  // Opt-in mailinglijsten: enkel de aangeduide categorieën zitten in de array.
  mailCategories     MailCategory[]   @default([])
  // Studie: meerdere studiejaren en richtingen mogelijk (iemand kan bv. deels in
  // 2de en deels in 3de bachelor zitten).
  studyYears         StudyYear[]      @default([])
  studyProgrammes    StudyProgramme[] @default([])
  // Lid dat niet aan de faculteit Ingenieurswetenschappen studeert. Bewust geen
  // `StudyProgramme`-waarde: het is geen richting, en als enum-waarde zou het
  // overal opduiken waar richtingen opgelijst worden (o.a. de career-export).
  notAtFaculty       Boolean          @default(false)
  // Werkingsjaar waarin het lid zijn studieprofiel laatst bevestigde (2026 =
  // "26-27"). Loopt dat achter op het huidige werkingsjaar, dan is het profiel
  // verlopen: de bevestigingsgate vraagt het opnieuw en het lid valt zolang uit
  // de mailinglijsten. Zo blijft "actief student" een jaarlijks vers signaal
  // zonder koppeling met de cursusdienst.
  studyConfirmedYear Int?

  sessions  Session[]
  accounts  Account[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  memberships         GroupMembership[]
  roles               UserRole[]
  pocRepresentative   PocRepresentative[]
  createdPages        Page[]                  @relation("PageCreatedBy")
  createdEvents       CalendarEvent[]         @relation("EventCreatedBy")
  dashboardTiles      DashboardTile[]
  dashboardTilePrefs  UserDashboardTilePref[]
  participatingShifts ShiftParticipant[]
  createdShortLinks   ShortLink[]             @relation("ShortLinkCreatedBy")

  theokotOrders   TheokotOrder[] @relation("TheokotOrderUser")
  theokotPickedUp TheokotOrder[] @relation("TheokotPickedUpBy")
  theokotBans     TheokotBan[]

  createdTicketEvents      TicketEvent[]           @relation("TicketEventCreatedBy")
  ticketEventGrants        TicketEventUserGrant[]  @relation("TicketEventGrantUser")
  ticketEventGrantsGiven   TicketEventUserGrant[]  @relation("TicketEventGrantGrantedBy")
  ticketGroupGrantsGiven   TicketEventGroupGrant[] @relation("TicketEventGroupGrantGrantedBy")
  ticketOrders             TicketOrder[]           @relation("TicketOrderBuyer")
  requestedTicketRefunds   TicketRefund[]          @relation("TicketRefundRequestedBy")
  createdTicketScanDevices TicketScanDevice[]      @relation("TicketScanDeviceCreatedBy")
  ticketScans              TicketScanLog[]         @relation("TicketScanActor")
  ticketAuditLogs          TicketAuditLog[]        @relation("TicketAuditActor")
  checkedInTickets         Ticket[]                @relation("TicketCheckedInBy")
}

model Group {
  id                String  @id @default(cuid())
  // Vrije, GUI-beheerde code (was een `GroupCode`-enum). Uniek, en de waarde die
  // shiften opslaan in `Shift.post` en de sessie meegeeft als `groups[].code`.
  code              String  @unique
  slug              String  @unique
  nameNl            String
  nameEn            String
  descriptionNl     String?
  descriptionEn     String?
  orderInPraesidium Int     @default(0)
  photoKey          String?
  // Een gedeactiveerde post verdwijnt uit de nieuwe-shift-keuzes en het
  // postenbeheer voor nieuwe jaren, maar de historiek (memberships per jaar)
  // blijft bewaard i.p.v. de post te verwijderen.
  active            Boolean @default(true)

  memberships       GroupMembership[]
  // Rollen die deze post toekent aan haar leden (DEFAULT) en verantwoordelijke (LEADER).
  roleGrants        GroupRole[]
  events            CalendarEvent[]
  dashboardTiles    DashboardTile[]
  ownedTicketEvents TicketEvent[]           @relation("TicketEventOwnerGroup")
  ticketEventGrants TicketEventGroupGrant[]
}

model GroupMembership {
  id           String         @id @default(cuid())
  userId       String
  groupId      String
  role         MembershipRole @default(MEMBER)
  // Werkingsjaar (startjaar van het academiejaar): 2026 = "26-27". Elk jaar is
  // een aparte rij, zodat de historiek per post per jaar bewaard blijft en een
  // nieuw werkingsjaar automatisch met een lege post begint.
  year         Int
  titleNl      String?
  titleEn      String?
  displayOrder Int            @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, year])
  @@index([groupId])
  @@index([year])
}

model Permission {
  id       String @id @default(cuid())
  code     String @unique
  labelNl  String
  labelEn  String
  category String @default("general")

  roles RolePermission[]
}

// Een rol bundelt rechten. Leden krijgen rollen direct (UserRole) of via een
// post (GroupRole). Roldefinities blijven over de jaren heen bestaan; enkel de
// toewijzingen zijn werkingsjaar-gebonden (zie UserRole) en resetten op 15 juli.
// `system` markeert rollen die de GUI niet mag verwijderen (bv. admin).
model Role {
  id            String   @id @default(cuid())
  code          String   @unique
  nameNl        String
  nameEn        String
  descriptionNl String?
  descriptionEn String?
  // Optionele accentkleur voor de rol-pill in de UI (key in het paletsysteem).
  color         String?
  order         Int      @default(0)
  system        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]
  groupGrants GroupRole[]
  pageGrants  PageEditorRole[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// Directe roltoewijzing aan een gebruiker, per werkingsjaar (2026 = "26-27").
// Net als GroupMembership per jaar: een nieuw werkingsjaar begint met een lege
// toewijzing (de 15-juli-reset) en de historiek blijft bewaard. De uitzondering
// die niet reset is `User.isSuperAdmin` (een boolean, geen toewijzing).
model UserRole {
  userId String
  roleId String
  year   Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId, year])
  @@index([userId])
  @@index([roleId])
  @@index([year])
}

// Rollen die een post automatisch toekent. DEFAULT geldt voor elk lid, LEADER
// enkel voor de verantwoordelijke (bovenop DEFAULT). Deze grants worden niet per
// persoon opgeslagen: de sessie-resolver leidt ze af uit de lidmaatschappen.
model GroupRole {
  groupId String
  roleId  String
  kind    RoleGrantKind @default(DEFAULT)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([groupId, roleId, kind])
  @@index([groupId])
  @@index([roleId])
}

// -----------------------------------------------------------------------------
// Header tabs & pages CMS
// -----------------------------------------------------------------------------

model HeaderTab {
  id      String  @id @default(cuid())
  code    String  @unique
  slug    String  @unique
  labelNl String
  labelEn String
  order   Int     @default(0)
  visible Boolean @default(true)

  // Foto op de aanbod-kaart van deze werking op de homepage (storage-key,
  // uploadbaar via /admin/home). Zonder foto valt de kaart terug op het
  // gestreepte placeholder-patroon of de statische default in HomeEditorial.
  imageKey String?

  // Inhoud van de categoriepagina zelf, bewerkbaar via /admin/inhoud.
  introNl    String?
  introEn    String?
  // Optionele knop naast de titel (bv. cudi.vtk.be bij Cursusdienst).
  ctaLabelNl String?
  ctaLabelEn String?
  ctaUrl     String?

  pages Page[]
}

model Page {
  id              String    @id @default(cuid())
  slug            String    @unique
  headerTabId     String?
  visibleInHeader Boolean   @default(true)
  titleNl         String
  titleEn         String?
  // Legacy tiptap-documenten. Markdown (contentMdNl/En) is de bron van waarheid;
  // deze JSON wordt enkel nog gerenderd zolang de pagina niet één keer in de
  // markdown-editor opgeslagen is.
  contentJsonNl   Json
  contentJsonEn   Json?
  contentMdNl     String?
  contentMdEn     String?
  excerptNl       String?
  excerptEn       String?
  // Jaarlijks na te kijken pagina (namen, telefoonnummers, ...): komt bovenaan
  // het paginabeheer te staan zolang ze dit werkingsjaar niet bewerkt is.
  needsYearlyEdit Boolean   @default(false)
  // Laatste keer dat de INHOUD via de editor opgeslagen is. updatedAt telt niet:
  // die verschuift ook bij structuurwijzigingen (verslepen, hernoemen, ...).
  contentEditedAt DateTime?
  publishedAt     DateTime?
  order           Int       @default(0)
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  headerTab   HeaderTab?       @relation(fields: [headerTabId], references: [id], onDelete: SetNull)
  createdBy   User?            @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assets      PageAsset[]
  editorRoles PageEditorRole[]

  @@index([headerTabId])
}

// Rollen die de inhoud van een pagina mogen bewerken (naast superadmin en
// pages.editAll). Een pagina zonder rijen hier is vergrendeld voor gewone
// pages.edit-houders.
model PageEditorRole {
  pageId String
  roleId String

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([pageId, roleId])
  @@index([roleId])
}

model PageAsset {
  id         String        @id @default(cuid())
  pageId     String
  storageKey String
  kind       PageAssetKind
  labelNl    String
  labelEn    String?
  sizeBytes  Int?
  mimeType   String?
  order      Int           @default(0)
  createdAt  DateTime      @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

// -----------------------------------------------------------------------------
// Calendar
// -----------------------------------------------------------------------------

model CalendarEvent {
  id            String          @id @default(cuid())
  titleNl       String
  titleEn       String?
  descriptionNl String?
  descriptionEn String?
  location      String?
  start         DateTime
  end           DateTime
  allDay        Boolean         @default(false)
  visibility    EventVisibility @default(PUBLIC)
  url           String?
  imageKey      String?
  groupId       String
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  ticketEvent TicketEvent?

  @@index([start])
  @@index([groupId])
}

// -----------------------------------------------------------------------------
// Integrated ticketing
// -----------------------------------------------------------------------------

model TicketEvent {
  id                    String            @id @default(cuid())
  calendarEventId       String?           @unique
  ownerGroupId          String
  slug                  String            @unique
  titleNl               String
  titleEn               String?
  descriptionNl         String?
  descriptionEn         String?
  location              String?
  startsAt              DateTime          @db.Timestamptz(3)
  endsAt                DateTime          @db.Timestamptz(3)
  timeZone              String            @default("Europe/Brussels")
  salesStartAt          DateTime?         @db.Timestamptz(3)
  salesEndAt            DateTime?         @db.Timestamptz(3)
  status                TicketEventStatus @default(DRAFT)
  currency              String            @default("EUR")
  maxTicketsPerOrder    Int               @default(8)
  contactEmail          String?
  termsUrl              String?
  termsVersion          String?
  confirmationMessageNl String?
  confirmationMessageEn String?
  settings              Json              @default("{}")
  createdById           String?
  publishedAt           DateTime?         @db.Timestamptz(3)
  archivedAt            DateTime?         @db.Timestamptz(3)
  createdAt             DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime          @updatedAt @db.Timestamptz(3)

  calendarEvent CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  ownerGroup    Group          @relation("TicketEventOwnerGroup", fields: [ownerGroupId], references: [id], onDelete: Restrict)
  createdBy     User?          @relation("TicketEventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  inventoryPools TicketInventoryPool[]
  ticketTypes    TicketType[]
  questions      TicketQuestion[]
  userGrants     TicketEventUserGrant[]
  groupGrants    TicketEventGroupGrant[]
  orders         TicketOrder[]
  orderItems     TicketOrderItem[]
  tickets        Ticket[]
  gates          TicketGate[]
  scanDevices    TicketScanDevice[]
  scanLogs       TicketScanLog[]
  auditLogs      TicketAuditLog[]
  outboxMessages TicketOutboxMessage[]

  @@index([ownerGroupId])
  @@index([status, salesStartAt, salesEndAt])
  @@index([startsAt])
}

model TicketInventoryPool {
  id            String   @id @default(cuid())
  eventId       String
  code          String
  nameNl        String
  nameEn        String?
  capacity      Int
  reservedCount Int      @default(0)
  soldCount     Int      @default(0)
  version       Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  event       TicketEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypes TicketType[]
  orderItems  TicketOrderItem[]

  @@unique([eventId, code])
  @@unique([id, eventId])
  @@index([eventId, active])
}

model TicketType {
  id              String         @id @default(cuid())
  eventId         String
  inventoryPoolId String
  code            String
  nameNl          String
  nameEn          String?
  descriptionNl   String?
  descriptionEn   String?
  unitPriceCents  Int
  currency        String         @default("EUR")
  audience        TicketAudience @default(PUBLIC)
  salesStartAt    DateTime?      @db.Timestamptz(3)
  salesEndAt      DateTime?      @db.Timestamptz(3)
  minPerOrder     Int            @default(1)
  maxPerOrder     Int            @default(8)
  active          Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(3)

  event         TicketEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  inventoryPool TicketInventoryPool @relation(fields: [inventoryPoolId, eventId], references: [id, eventId], onDelete: Restrict)
  questions     TicketQuestion[]
  orderItems    TicketOrderItem[]

  @@unique([eventId, code])
  @@unique([id, eventId])
  @@index([eventId, active, sortOrder])
  @@index([inventoryPoolId])
}

model TicketQuestion {
  id            String             @id @default(cuid())
  eventId       String
  ticketTypeId  String?
  code          String
  labelNl       String
  labelEn       String?
  descriptionNl String?
  descriptionEn String?
  type          TicketQuestionType
  required      Boolean            @default(false)
  options       Json?
  active        Boolean            @default(true)
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(3)

  event      TicketEvent             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType TicketType?             @relation(fields: [ticketTypeId, eventId], references: [id, eventId], onDelete: Restrict)
  answers    TicketOrderItemAnswer[]

  @@unique([eventId, code])
  @@unique([id, eventId])
  @@index([eventId, active, sortOrder])
  @@index([ticketTypeId])
}

model TicketEventUserGrant {
  id          String          @id @default(cuid())
  eventId     String
  userId      String
  role        TicketGrantRole
  grantedById String?
  createdAt   DateTime        @default(now()) @db.Timestamptz(3)

  event     TicketEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User        @relation("TicketEventGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User?       @relation("TicketEventGrantGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([userId])
}

model TicketEventGroupGrant {
  id          String                @id @default(cuid())
  eventId     String
  groupId     String
  role        TicketGrantRole
  scope       TicketGroupGrantScope @default(ALL_MEMBERS)
  grantedById String?
  createdAt   DateTime              @default(now()) @db.Timestamptz(3)

  event     TicketEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  grantedBy User?       @relation("TicketEventGroupGrantGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([eventId, groupId])
  @@index([groupId])
}

model TicketOrder {
  id                   String            @id @default(cuid())
  eventId              String
  reference            String            @unique
  accessTokenHash      String            @unique
  accessExpiresAt      DateTime          @db.Timestamptz(3)
  requestFingerprint   String?
  buyerUserId          String?
  buyerName            String
  buyerEmail           String
  locale               Locale            @default(NL)
  status               TicketOrderStatus @default(PENDING_PAYMENT)
  currency             String            @default("EUR")
  subtotalCents        Int
  discountCents        Int               @default(0)
  totalCents           Int
  refundedCents        Int               @default(0)
  reservationExpiresAt DateTime?         @db.Timestamptz(3)
  termsAcceptedAt      DateTime?         @db.Timestamptz(3)
  termsVersion         String?
  paidAt               DateTime?         @db.Timestamptz(3)
  failedAt             DateTime?         @db.Timestamptz(3)
  expiredAt            DateTime?         @db.Timestamptz(3)
  cancelledAt          DateTime?         @db.Timestamptz(3)
  createdAt            DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime          @updatedAt @db.Timestamptz(3)

  event          TicketEvent           @relation(fields: [eventId], references: [id], onDelete: Restrict)
  buyer          User?                 @relation("TicketOrderBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  items          TicketOrderItem[]
  payments       TicketPayment[]
  refunds        TicketRefund[]
  outboxMessages TicketOutboxMessage[]

  @@unique([id, eventId])
  @@index([eventId, status, createdAt])
  @@index([eventId, requestFingerprint, createdAt])
  @@index([buyerUserId])
  @@index([buyerEmail])
  @@index([status, reservationExpiresAt])
}

// Each order item represents exactly one attendee and can issue at most one ticket.
model TicketOrderItem {
  id              String   @id @default(cuid())
  eventId         String
  orderId         String
  ticketTypeId    String
  inventoryPoolId String
  ticketTypeCode  String
  ticketTypeName  String
  unitPriceCents  Int
  discountCents   Int      @default(0)
  totalCents      Int
  attendeeName    String
  attendeeEmail   String?
  createdAt       DateTime @default(now()) @db.Timestamptz(3)

  event         TicketEvent             @relation(fields: [eventId], references: [id], onDelete: Restrict)
  order         TicketOrder             @relation(fields: [orderId, eventId], references: [id, eventId], onDelete: Restrict)
  ticketType    TicketType              @relation(fields: [ticketTypeId, eventId], references: [id, eventId], onDelete: Restrict)
  inventoryPool TicketInventoryPool     @relation(fields: [inventoryPoolId, eventId], references: [id, eventId], onDelete: Restrict)
  answers       TicketOrderItemAnswer[]
  ticket        Ticket?
  refundItems   TicketRefundItem[]

  @@unique([id, eventId])
  @@unique([id, orderId])
  @@index([orderId])
  @@index([eventId, ticketTypeId])
  @@index([inventoryPoolId])
}

model TicketOrderItemAnswer {
  id            String   @id @default(cuid())
  eventId       String
  orderItemId   String
  questionId    String
  questionCode  String
  questionLabel String
  value         Json
  createdAt     DateTime @default(now()) @db.Timestamptz(3)

  orderItem TicketOrderItem @relation(fields: [orderItemId, eventId], references: [id, eventId], onDelete: Restrict)
  question  TicketQuestion  @relation(fields: [questionId, eventId], references: [id, eventId], onDelete: Restrict)

  @@unique([orderItemId, questionId])
  @@index([questionId])
}

model TicketPayment {
  id                 String              @id @default(cuid())
  orderId            String
  provider           String
  providerCheckoutId String?
  providerPaymentId  String?
  idempotencyKey     String
  status             TicketPaymentStatus @default(CREATED)
  amountCents        Int
  currency           String              @default("EUR")
  checkoutUrl        String?
  providerStatus     String?
  expiresAt          DateTime?           @db.Timestamptz(3)
  succeededAt        DateTime?           @db.Timestamptz(3)
  failedAt           DateTime?           @db.Timestamptz(3)
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)

  order    TicketOrder            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  webhooks TicketPaymentWebhook[]
  refunds  TicketRefund[]

  @@unique([provider, providerCheckoutId])
  @@unique([provider, providerPaymentId])
  @@unique([provider, idempotencyKey])
  @@unique([id, orderId])
  @@index([orderId, status])
  @@index([status, expiresAt])
}

model TicketPaymentWebhook {
  id                 String    @id @default(cuid())
  provider           String
  externalEventId    String
  paymentId          String?
  signatureValid     Boolean
  payload            Json
  processingAttempts Int       @default(0)
  receivedAt         DateTime  @default(now()) @db.Timestamptz(3)
  processedAt        DateTime? @db.Timestamptz(3)
  lastError          String?

  payment TicketPayment? @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@unique([provider, externalEventId])
  @@index([paymentId])
  @@index([processedAt, receivedAt])
}

model Ticket {
  id                String       @id @default(cuid())
  eventId           String
  orderItemId       String       @unique
  publicCode        String       @unique
  credentialHash    String       @unique
  credentialVersion Int          @default(1)
  status            TicketStatus @default(VALID)
  issuedAt          DateTime     @default(now()) @db.Timestamptz(3)
  checkedInAt       DateTime?    @db.Timestamptz(3)
  checkedInById     String?
  voidedAt          DateTime?    @db.Timestamptz(3)
  refundedAt        DateTime?    @db.Timestamptz(3)

  event       TicketEvent     @relation(fields: [eventId], references: [id], onDelete: Restrict)
  orderItem   TicketOrderItem @relation(fields: [orderItemId, eventId], references: [id, eventId], onDelete: Restrict)
  checkedInBy User?           @relation("TicketCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)
  scanLogs    TicketScanLog[]

  @@unique([id, eventId])
  @@unique([orderItemId, eventId])
  @@index([eventId, status])
  @@index([eventId, checkedInAt])
  @@index([checkedInById])
}

model TicketRefund {
  id               String             @id @default(cuid())
  orderId          String
  paymentId        String
  provider         String
  providerRefundId String?
  idempotencyKey   String
  status           TicketRefundStatus @default(PENDING)
  amountCents      Int
  currency         String             @default("EUR")
  reason           String?
  requestedById    String?
  createdAt        DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(3)
  completedAt      DateTime?          @db.Timestamptz(3)

  order       TicketOrder        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment     TicketPayment      @relation(fields: [paymentId, orderId], references: [id, orderId], onDelete: Restrict)
  requestedBy User?              @relation("TicketRefundRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  items       TicketRefundItem[]

  @@unique([provider, providerRefundId])
  @@unique([provider, idempotencyKey])
  @@unique([id, orderId])
  @@index([orderId, status])
  @@index([paymentId])
  @@index([requestedById])
}

model TicketRefundItem {
  id          String @id @default(cuid())
  orderId     String
  refundId    String
  orderItemId String
  amountCents Int

  refund    TicketRefund    @relation(fields: [refundId, orderId], references: [id, orderId], onDelete: Restrict)
  orderItem TicketOrderItem @relation(fields: [orderItemId, orderId], references: [id, orderId], onDelete: Restrict)

  @@unique([refundId, orderItemId])
  @@index([orderItemId])
}

model TicketGate {
  id        String   @id @default(cuid())
  eventId   String
  code      String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  event    TicketEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scanLogs TicketScanLog[]

  @@unique([eventId, code])
  @@unique([id, eventId])
  @@index([eventId, active])
}

model TicketScanDevice {
  id          String    @id @default(cuid())
  eventId     String
  label       String
  tokenHash   String    @unique
  createdById String?
  lastSeenAt  DateTime? @db.Timestamptz(3)
  revokedAt   DateTime? @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)

  event     TicketEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("TicketScanDeviceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  scanLogs  TicketScanLog[]

  @@unique([id, eventId])
  @@index([eventId, revokedAt])
  @@index([createdById])
}

model TicketScanLog {
  id                    String           @id @default(cuid())
  eventId               String
  ticketId              String?
  scannerUserId         String?
  deviceId              String?
  gateId                String?
  clientScanId          String           @unique
  result                TicketScanResult
  credentialFingerprint String?
  scannedAt             DateTime         @default(now()) @db.Timestamptz(3)
  clientScannedAt       DateTime?        @db.Timestamptz(3)
  reversesScanId        String?          @unique
  metadata              Json?

  event        TicketEvent       @relation(fields: [eventId], references: [id], onDelete: Restrict)
  ticket       Ticket?           @relation(fields: [ticketId, eventId], references: [id, eventId], onDelete: Restrict)
  scannerUser  User?             @relation("TicketScanActor", fields: [scannerUserId], references: [id], onDelete: SetNull)
  device       TicketScanDevice? @relation(fields: [deviceId, eventId], references: [id, eventId], onDelete: Restrict)
  gate         TicketGate?       @relation(fields: [gateId, eventId], references: [id, eventId], onDelete: Restrict)
  reversesScan TicketScanLog?    @relation("TicketScanReversal", fields: [reversesScanId], references: [id], onDelete: Restrict)
  reversedBy   TicketScanLog?    @relation("TicketScanReversal")

  @@index([eventId, scannedAt])
  @@index([ticketId, scannedAt])
  @@index([scannerUserId])
  @@index([deviceId])
  @@index([gateId])
}

model TicketAuditLog {
  id          String   @id @default(cuid())
  eventId     String
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  event     TicketEvent @relation(fields: [eventId], references: [id], onDelete: Restrict)
  actorUser User?       @relation("TicketAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([eventId, entityType, entityId])
  @@index([actorUserId])
}

model TicketOutboxMessage {
  id          String             @id @default(cuid())
  eventId     String?
  orderId     String?
  type        String
  dedupeKey   String             @unique
  recipient   String?
  payload     Json
  status      TicketOutboxStatus @default(PENDING)
  attempts    Int                @default(0)
  availableAt DateTime           @default(now()) @db.Timestamptz(3)
  lockedAt    DateTime?          @db.Timestamptz(3)
  lockedBy    String?
  lastError   String?
  sentAt      DateTime?          @db.Timestamptz(3)
  createdAt   DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime           @updatedAt @db.Timestamptz(3)

  event TicketEvent? @relation(fields: [eventId], references: [id], onDelete: Restrict)
  order TicketOrder? @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([status, availableAt])
  @@index([eventId])
  @@index([orderId])
}

// -----------------------------------------------------------------------------
// Photo albums
// -----------------------------------------------------------------------------

model PhotoAlbum {
  id            String    @id @default(cuid())
  slug          String    @unique
  titleNl       String
  titleEn       String?
  descriptionNl String?
  descriptionEn String?
  coverPhotoId  String?   @unique
  eventDate     DateTime?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  coverPhoto Photo?  @relation("AlbumCover", fields: [coverPhotoId], references: [id], onDelete: SetNull)
  photos     Photo[] @relation("AlbumPhotos")
}

model Photo {
  id           String    @id @default(cuid())
  albumId      String
  storageKey   String
  thumbnailKey String?
  width        Int?
  height       Int?
  sizeBytes    Int?
  originalName String?
  takenAt      DateTime?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())

  album        PhotoAlbum  @relation("AlbumPhotos", fields: [albumId], references: [id], onDelete: Cascade)
  coverOfAlbum PhotoAlbum? @relation("AlbumCover")

  @@index([albumId])
}

// -----------------------------------------------------------------------------
// POCs (student representatives per study track)
// -----------------------------------------------------------------------------

model Poc {
  id            String  @id @default(cuid())
  slug          String  @unique
  nameNl        String
  nameEn        String?
  studyTrack    String
  descriptionNl String?
  descriptionEn String?
  order         Int     @default(0)

  representatives PocRepresentative[]
}

model PocRepresentative {
  id     String  @id @default(cuid())
  pocId  String
  userId String
  roleNl String?
  roleEn String?
  order  Int     @default(0)

  poc  Poc  @relation(fields: [pocId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pocId, userId])
}

// -----------------------------------------------------------------------------
// Partners
// -----------------------------------------------------------------------------

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoKey   String
  url       String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// Settings (key/value JSON, drives the editable homepage and opening hours)
// -----------------------------------------------------------------------------

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Admin dashboard tiles (configurable launchpad links)
// -----------------------------------------------------------------------------

model DashboardTile {
  id        String             @id @default(cuid())
  label     String
  url       String
  icon      String             @default("link") // key into curated icon set
  color     String             @default("navy") // key into color palette
  scope     DashboardTileScope
  groupId   String? // set when scope = GROUP
  userId    String? // set when scope = USER (personal tile)
  order     Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  group Group?                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prefs UserDashboardTilePref[]

  @@index([scope])
  @@index([groupId])
  @@index([userId])
}

// Per-user override of a shared (GLOBAL/GROUP) tile: hide it, reorder it, or
// override its display fields. Personal (USER) tiles are edited directly.
model UserDashboardTilePref {
  userId String
  tileId String
  hidden Boolean @default(false)
  order  Int?
  label  String? // null = inherit from the default tile
  url    String?
  icon   String?
  color  String?

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tile DashboardTile @relation(fields: [tileId], references: [id], onDelete: Cascade)

  @@id([userId, tileId])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// Shifts
// -----------------------------------------------------------------------------

model Shift {
  id String @id @default(cuid())

  participantIds Int[]
  participants   ShiftParticipant[]

  name            String
  startTime       DateTime
  endTime         DateTime
  location        String
  description     String
  maxParticipants Int
  reward          Int

  // Postcode (Group.code) waarvoor deze shift telt; los tekstveld i.p.v. een
  // relatie, zodat een oude postcode behouden blijft ook als de post later
  // gedeactiveerd of hernoemd wordt.
  post String?
  // Ook een field bijhouden voor het evenement waarbij de shift hoort?
}

model ShiftParticipant {
  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  payedOut Boolean

  @@id([shiftId, userId])
}

// -----------------------------------------------------------------------------
// Short links (on.vtk.be/<slug> -> target URL)
// -----------------------------------------------------------------------------

model ShortLink {
  id          String    @id @default(cuid())
  slug        String    @unique
  url         String
  enabled     Boolean   @default(true)
  clicks      Int       @default(0)
  note        String?
  expiresAt   DateTime? // when set, the link stops resolving after this instant
  createdById String?
  createdBy   User?     @relation("ShortLinkCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// -----------------------------------------------------------------------------
// Theokot (cafetaria / broodjesbar) reservatiesysteem
//
// Zie docs/design-decisions.md voor de niet-vanzelfsprekende keuzes achter dit
// systeem (bestelvenster, annulatie-deadline, no-show/ban-logica, turf-lijst,
// snapshots i.p.v. live catalogus).
// -----------------------------------------------------------------------------

/// Catalogus met het standaardaanbod. Prijs in eurocent (Int, geen floats).
/// Bij het aanmaken van een week worden deze rijen naar `TheokotSessionItem`
/// gekopieerd (snapshot), zodat latere catalogus-edits oude sessies niet wijzigen.
model TheokotProduct {
  id                  String   @id @default(cuid())
  nameNl              String
  nameEn              String?
  priceCents          Int
  defaultQuantity     Int      @default(0)
  isWeeklySpecialSlot Boolean  @default(false) // "broodje van de week"-slot
  order               Int      @default(0)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Eén verkoopsessie = één open dag. Uren en aanbod zijn per dag aanpasbaar;
/// `isOpen=false` betekent dat Theokot die dag dicht is. De venster-momenten
/// (order/pickup) worden bij aanmaak berekend uit config + Brussel-tijd en
/// opgeslagen zodat ze daarna manueel bijgesteld kunnen worden.
model TheokotSession {
  id                   String    @id @default(cuid())
  date                 DateTime  @unique // lokale middernacht van de verkoopdag
  isOpen               Boolean   @default(true)
  orderOpenAt          DateTime // vanaf wanneer studenten kunnen bestellen
  orderCloseAt         DateTime // annulatie-/besteldeadline (turf-lijst wordt geprint)
  pickupStart          DateTime
  pickupEnd            DateTime
  weeklySpecialLabelNl String? // welk broodje deze week "van de week" is
  weeklySpecialLabelEn String?
  processedAt          DateTime? // wanneer no-shows verwerkt zijn (idempotentie)
  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  items  TheokotSessionItem[]
  orders TheokotOrder[]

  @@index([date])
}

/// Aanbod van één sessie (snapshot van een product op het moment van aanmaken).
model TheokotSessionItem {
  id              String  @id @default(cuid())
  sessionId       String
  productId       String? // herkomst-catalogusitem, puur informatief
  nameNl          String
  nameEn          String?
  priceCents      Int
  quantity        Int // beschikbare voorraad voor deze sessie
  isWeeklySpecial Boolean @default(false)
  order           Int     @default(0)

  session TheokotSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lines   TheokotOrderLine[]

  @@index([sessionId])
}

/// Eén bestelling per persoon per sessie.
model TheokotOrder {
  id           String             @id @default(cuid())
  sessionId    String
  userId       String
  status       TheokotOrderStatus @default(RESERVED)
  totalCents   Int
  statusNote   String? // vrije notitie bij correcties
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  pickedUpAt   DateTime?
  pickedUpById String? // wie aan de balie op "opgehaald" drukte

  session    TheokotSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User               @relation("TheokotOrderUser", fields: [userId], references: [id], onDelete: Cascade)
  pickedUpBy User?              @relation("TheokotPickedUpBy", fields: [pickedUpById], references: [id], onDelete: SetNull)
  lines      TheokotOrderLine[]

  @@unique([sessionId, userId])
  @@index([userId])
  @@index([status])
}

model TheokotOrderLine {
  id             String @id @default(cuid())
  orderId        String
  sessionItemId  String
  quantity       Int
  unitPriceCents Int // snapshot van de prijs op besteldatum

  order       TheokotOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sessionItem TheokotSessionItem @relation(fields: [sessionItemId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([sessionItemId])
}

/// Tijdelijke ban na te veel no-shows. Historiek blijft bewaard; een ban
/// opheffen zet `active=false` (i.p.v. verwijderen) zodat correcties zichtbaar blijven.
model TheokotBan {
  id          String   @id @default(cuid())
  userId      String
  reason      String
  startsAt    DateTime @default(now())
  endsAt      DateTime
  active      Boolean  @default(true)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

// -----------------------------------------------------------------------------
// better-auth specific tables
// -----------------------------------------------------------------------------

model Session {
  id        String   @id
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
